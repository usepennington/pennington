@page "/"
@inject PenningtonOptions PenningtonOptions

<PageTitle>@PenningtonOptions.SiteTitle</PageTitle>

<h1 class="text-4xl font-bold pb-4">@PenningtonOptions.SiteTitle</h1>
<p class="text-neutral-600 text-lg pb-6">Internal Developer Portal — docs, blog, and tools in one place.</p>

<div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <a href="/docs/getting-started/" class="block p-4 border rounded hover:bg-neutral-50">
        <h2 class="font-semibold">Documentation</h2>
        <p class="text-sm text-neutral-500">Guides and API references</p>
    </a>
    <a href="/blog/welcome/" class="block p-4 border rounded hover:bg-neutral-50">
        <h2 class="font-semibold">Blog</h2>
        <p class="text-sm text-neutral-500">Team updates and announcements</p>
    </a>
    <a href="/about/" class="block p-4 border rounded hover:bg-neutral-50">
        <h2 class="font-semibold">About</h2>
        <p class="text-sm text-neutral-500">About the Forge platform</p>
    </a>
</div>
