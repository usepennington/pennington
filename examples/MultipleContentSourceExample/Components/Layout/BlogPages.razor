@page "/blog/{*fileName:nonfile}"
@inject PennOptions PennOptions
@inject ContentHelper ContentHelper

@if (_html == null || _frontMatter == null)
{
    <PageTitle>@PennOptions.SiteTitle</PageTitle>
    <p>Blog not found</p>
    return;
}
<PageTitle>@PennOptions.SiteTitle - @_frontMatter.Title</PageTitle>
<article>
    <header>
        <p>Blog</p>
        <h1 class="text-4xl font-bold"> @_frontMatter.Title</h1>
    </header>

    <div class="prose max-w-full">
        @((MarkupString)_html)
    </div>
</article>

@code {
    private BlogFrontMatter? _frontMatter;
    private string? _html;

    [Parameter] public required string FileName { get; init; } = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var fileName = FileName?.TrimEnd('/') ?? string.Empty;
        var url = string.IsNullOrWhiteSpace(fileName)
            ? "/blog"
            : $"/blog/{fileName}";

        var page = await ContentHelper.GetRenderedPageAsync<BlogFrontMatter>(url);
        if (page == null)
        {
            return;
        }

        _frontMatter = page.FrontMatter;
        _html = page.Html;
    }
}
