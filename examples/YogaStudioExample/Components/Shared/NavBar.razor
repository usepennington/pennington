@inject NavigationManager Nav

<header class="yoga-nav">
    <div class="yoga-container">
        <div class="flex items-center justify-between h-16 px-6">
            <!-- Logo -->
            <a href="/" class="flex items-center gap-2 text-primary-800 dark:text-primary-300 hover:text-primary-600 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="4" r="1.5"/>
                    <path d="M12 5.5V10M12 10L8 17M12 10L16 17M8 17L6 21M16 17L18 21M9 13H15"/>
                </svg>
                <span class="font-display text-xl font-bold tracking-tight">937 Yoga</span>
            </a>

            <!-- Desktop Nav -->
            <nav class="hidden md:flex items-center gap-6">
                <NavLink href="/" class="@NavCss("/")" Match="NavLinkMatch.All">Home</NavLink>
                <NavLink href="/schedule" class="@NavCss("/schedule")">Classes</NavLink>
                <NavLink href="/instructors" class="@NavCss("/instructors")">Instructors</NavLink>
                <NavLink href="/blog" class="@NavCss("/blog")">Blog</NavLink>
                <NavLink href="/about" class="@NavCss("/about")">About</NavLink>
                <NavLink href="/pricing" class="@NavCss("/pricing")">Pricing</NavLink>
                <NavLink href="/contact" class="@NavCss("/contact")">Contact</NavLink>
            </nav>

            <!-- Right side: search + language -->
            <div class="flex items-center gap-3">
                <button onclick="window.openSearch && window.openSearch()"
                        class="hidden md:flex items-center gap-2 px-3 py-1.5 rounded-lg border border-base-300 text-sm text-base-500 hover:border-primary-400 hover:text-primary-600 transition-colors dark:border-base-600 dark:text-base-400 dark:hover:border-primary-500">
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                    </svg>
                    <span class="text-xs text-base-400">Ctrl+K</span>
                </button>

                <LanguageSwitcher />

                <!-- Mobile menu button -->
                <button onclick="document.getElementById('mobile-menu').classList.toggle('hidden')"
                        class="md:hidden p-2 rounded-lg text-base-600 hover:bg-base-100 dark:text-base-300 dark:hover:bg-base-800">
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
                    </svg>
                </button>
            </div>
        </div>

        <!-- Mobile Nav -->
        <nav id="mobile-menu" class="hidden md:hidden border-t border-base-200 px-6 py-4 space-y-2 dark:border-base-700">
            <a href="/" class="block py-2 yoga-nav-link">Home</a>
            <a href="/schedule" class="block py-2 yoga-nav-link">Classes</a>
            <a href="/instructors" class="block py-2 yoga-nav-link">Instructors</a>
            <a href="/blog" class="block py-2 yoga-nav-link">Blog</a>
            <a href="/about" class="block py-2 yoga-nav-link">About</a>
            <a href="/pricing" class="block py-2 yoga-nav-link">Pricing</a>
            <a href="/contact" class="block py-2 yoga-nav-link">Contact</a>
            <button onclick="window.openSearch && window.openSearch()"
                    class="block w-full text-left py-2 yoga-nav-link">
                Search...
            </button>
        </nav>
    </div>
</header>

@code {
    private string NavCss(string path)
    {
        var uri = new Uri(Nav.Uri);
        var current = uri.AbsolutePath.TrimEnd('/');
        var target = path.TrimEnd('/');

        if (string.IsNullOrEmpty(target))
            return current == "" || current == "/" ? "yoga-nav-link-active" : "yoga-nav-link";

        return current.StartsWith(target, StringComparison.OrdinalIgnoreCase)
            ? "yoga-nav-link-active"
            : "yoga-nav-link";
    }
}
