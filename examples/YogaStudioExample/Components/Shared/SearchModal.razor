<!-- Search modal — behavior provided by inline script in App.razor -->
@*
    Hidden sentinel: the inline search script uses classList.add('bg-base-50',
    'dark:bg-base-800') to highlight the active result row. Those Tailwind
    utilities are not used statically anywhere else, so MonorailCSS' HTML-class
    scanner wouldn't emit them. Listing them in a never-rendered class
    attribute forces the collector to include them in the stylesheet.
*@
<span class="hidden bg-base-50 dark:bg-base-800" aria-hidden="true"></span>

<div id="search-modal" class="search-modal-backdrop" style="display:none;">
    <div class="search-modal-content">
        <div class="search-modal-header">
            <div class="search-modal-input-container">
                <svg class="search-modal-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                </svg>
                <input id="search-input"
                       type="text"
                       class="search-modal-input"
                       placeholder="Search classes, instructors, blog posts..."
                       autocomplete="off"/>
            </div>
        </div>
        <div id="search-results" class="search-modal-results">
            <p class="search-modal-placeholder">Start typing to search...</p>
        </div>
        <div class="px-4 py-3 border-t border-base-200 dark:border-base-700 flex items-center justify-between text-xs text-base-400">
            <span>
                <kbd class="px-1.5 py-0.5 rounded border border-base-300 dark:border-base-600 font-mono text-xs">Esc</kbd>
                to close
            </span>
            <span>
                <kbd class="px-1.5 py-0.5 rounded border border-base-300 dark:border-base-600 font-mono text-xs">&uarr;&darr;</kbd>
                to navigate
            </span>
        </div>
    </div>
</div>
