@page "/faq"
@inject ContentHelper Content
@inject NavigationManager Nav

<PageTitle>FAQ — 937 Yoga</PageTitle>

<section class="yoga-section">
    <div class="yoga-container max-w-3xl">
        <div class="text-center mb-12">
            <h1 class="font-display text-4xl md:text-5xl font-bold text-base-900 dark:text-base-50 mb-4">Frequently Asked Questions</h1>
            <p class="text-base-500 dark:text-base-400 max-w-xl mx-auto">Everything you need to know before your first visit.</p>
        </div>

        <div id="faq-list" class="divide-y divide-base-200 dark:divide-base-700">
            @foreach (var (question, answer) in FaqItems)
            {
                <div class="yoga-faq-item" data-faq-item>
                    <button class="yoga-faq-question" data-faq-toggle>
                        <span>@question</span>
                        <svg class="h-5 w-5 text-base-400 shrink-0 transition-transform duration-200" data-faq-icon fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                        </svg>
                    </button>
                    <div class="yoga-faq-answer hidden" data-faq-content>
                        <p>@answer</p>
                    </div>
                </div>
            }
        </div>

        <!-- Additional markdown content -->
        @if (_html is not null)
        {
            <div class="mt-12 prose prose-base dark:prose-invert max-w-none">
                @((MarkupString)_html)
            </div>
        }

        <div class="text-center mt-12">
            <p class="text-base-500 dark:text-base-400 mb-4">Still have questions?</p>
            <a href="/contact" class="yoga-btn-primary">Contact Us</a>
        </div>
    </div>
</section>

@code {
    private string? _html;

    private static readonly List<(string Question, string Answer)> FaqItems =
    [
        ("What should I bring to my first class?", "Just yourself and comfortable clothing you can move in. We provide mats, blocks, straps, and blankets for every class. Bring a water bottle and a towel if you're coming to Hot Yoga."),
        ("Do I need experience to join?", "Not at all! Many of our classes are suitable for complete beginners. Our Community Flow on Saturday mornings is specifically designed for newcomers. Instructors always offer modifications."),
        ("How early should I arrive?", "Please arrive 10-15 minutes before your first class so we can get you set up and answer any questions. For returning students, 5 minutes early is plenty."),
        ("What is Hot Yoga, and is it safe?", "Our Hot Yoga classes are practiced in a room heated to about 95°F (35°C). The heat helps loosen muscles and promotes detoxification. Stay hydrated before, during, and after class. If you have heat sensitivity or cardiovascular concerns, consult your doctor first."),
        ("Can I attend classes while pregnant?", "Yes! We offer dedicated Prenatal Yoga classes with Alex on Thursdays. For other classes, let your instructor know you're pregnant and they'll offer appropriate modifications. We recommend starting prenatal-specific classes after the first trimester."),
        ("What's your cancellation policy?", "For drop-in and class pack reservations, please cancel at least 2 hours before class. Monthly unlimited members have no cancellation restrictions. Late cancellations for drop-in/pack users count as a used class."),
        ("Do you offer private sessions?", "Yes! All our instructors offer private one-on-one sessions. These are perfect for working on specific goals, injuries, or deepening your practice. Contact us to schedule and discuss rates."),
        ("Is there parking available?", "We have a small lot behind the studio with 12 spaces, plus ample street parking on Elm and adjacent streets. We're also a 5-minute walk from the Blue Line MAX stop."),
    ];

    protected override async Task OnInitializedAsync()
    {
        var url = new Uri(Nav.Uri).AbsolutePath;
        var result = await Content.GetStaticPageAsync(url);
        if (result.HasValue)
        {
            _html = result.Value.Html;
        }
    }
}
