@page "/instructors"
@inject InstructorService InstructorSvc

<PageTitle>Our Instructors — 937 Yoga</PageTitle>

<section class="yoga-section">
    <div class="yoga-container">
        <div class="text-center mb-12">
            <h1 class="font-display text-4xl md:text-5xl font-bold text-base-900 dark:text-base-50 mb-4">Our Instructors</h1>
            <p class="text-base-500 dark:text-base-400 max-w-xl mx-auto">
                Collectively over @(InstructorSvc.GetAll().Sum(i => i.YearsExperience)) years of experience.
                Each brings a unique perspective to the mat.
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            @foreach (var inst in InstructorSvc.GetAll())
            {
                <a href="/instructors/@inst.Slug" class="yoga-instructor-card">
                    <div class="yoga-instructor-avatar">
                        @inst.Name[0]@inst.Name.Split(' ').Last()[0]
                    </div>
                    <div class="p-6">
                        <h2 class="font-display text-xl font-bold text-base-900 dark:text-base-50 mb-1 group-hover:text-primary-700 dark:group-hover:text-primary-400 transition-colors">
                            @inst.Name
                        </h2>
                        <p class="text-sm text-primary-600 dark:text-primary-400 mb-3">@inst.Title</p>
                        <p class="text-sm text-base-600 dark:text-base-300 mb-4 line-clamp-3">@inst.Bio</p>
                        <div class="flex flex-wrap gap-2">
                            @foreach (var spec in inst.Specialties.Take(3))
                            {
                                <span class="yoga-tag">@spec</span>
                            }
                        </div>
                        <div class="mt-4 pt-4 border-t border-base-200 dark:border-base-700 flex items-center justify-between text-xs text-base-500 dark:text-base-400">
                            <span>@inst.YearsExperience years experience</span>
                            <span>@inst.Certifications.FirstOrDefault()</span>
                        </div>
                    </div>
                </a>
            }
        </div>
    </div>
</section>
