@page "/pricing"
@inject ContentHelper Content
@inject NavigationManager Nav

<PageTitle>Pricing — 937 Yoga</PageTitle>

<!-- Pricing Cards -->
<section class="yoga-section">
    <div class="yoga-container">
        <div class="text-center mb-12">
            <h1 class="font-display text-4xl md:text-5xl font-bold text-base-900 dark:text-base-50 mb-4">Simple, Honest Pricing</h1>
            <p class="text-base-500 dark:text-base-400 max-w-xl mx-auto">Your first class is always free. No contracts, no hidden fees.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto mb-16">
            <!-- Drop-in -->
            <div class="yoga-pricing-card">
                <h3 class="font-display text-xl font-bold text-base-900 dark:text-base-50 mb-2">Drop-In</h3>
                <p class="text-sm text-base-500 dark:text-base-400 mb-6">Perfect for visitors and occasional practitioners.</p>
                <div class="mb-6">
                    <span class="text-4xl font-bold text-base-900 dark:text-base-50">$22</span>
                    <span class="text-base-500 dark:text-base-400">/class</span>
                </div>
                <ul class="space-y-3 text-sm text-base-600 dark:text-base-300 mb-8 flex-1">
                    <li class="flex items-center gap-2">
                        <svg class="h-4 w-4 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                        Any single class
                    </li>
                    <li class="flex items-center gap-2">
                        <svg class="h-4 w-4 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                        Mat & props included
                    </li>
                    <li class="flex items-center gap-2">
                        <svg class="h-4 w-4 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                        No commitment
                    </li>
                </ul>
                <a href="/contact" class="yoga-btn-secondary w-full text-center">Book a Class</a>
            </div>

            <!-- Unlimited — Featured -->
            <div class="yoga-pricing-featured">
                <div class="absolute -top-3 left-1/2 -translate-x-1/2">
                    <span class="bg-primary-700 text-white text-xs font-semibold px-3 py-1 rounded-full">Most Popular</span>
                </div>
                <h3 class="font-display text-xl font-bold text-base-900 dark:text-base-50 mb-2">Unlimited</h3>
                <p class="text-sm text-base-500 dark:text-base-400 mb-6">For dedicated practitioners who want it all.</p>
                <div class="mb-6">
                    <span class="text-4xl font-bold text-base-900 dark:text-base-50">$139</span>
                    <span class="text-base-500 dark:text-base-400">/month</span>
                </div>
                <ul class="space-y-3 text-sm text-base-600 dark:text-base-300 mb-8 flex-1">
                    <li class="flex items-center gap-2">
                        <svg class="h-4 w-4 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                        Unlimited classes
                    </li>
                    <li class="flex items-center gap-2">
                        <svg class="h-4 w-4 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                        All class types including Hot Yoga
                    </li>
                    <li class="flex items-center gap-2">
                        <svg class="h-4 w-4 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                        Guest passes (2/month)
                    </li>
                    <li class="flex items-center gap-2">
                        <svg class="h-4 w-4 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                        10% off workshops
                    </li>
                </ul>
                <a href="/contact" class="yoga-btn-primary w-full text-center">Get Started</a>
            </div>

            <!-- Class Pack -->
            <div class="yoga-pricing-card">
                <h3 class="font-display text-xl font-bold text-base-900 dark:text-base-50 mb-2">10-Class Pack</h3>
                <p class="text-sm text-base-500 dark:text-base-400 mb-6">Flexible credits that never expire.</p>
                <div class="mb-6">
                    <span class="text-4xl font-bold text-base-900 dark:text-base-50">$180</span>
                    <span class="text-base-500 dark:text-base-400">/pack</span>
                </div>
                <ul class="space-y-3 text-sm text-base-600 dark:text-base-300 mb-8 flex-1">
                    <li class="flex items-center gap-2">
                        <svg class="h-4 w-4 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                        10 classes ($18/class)
                    </li>
                    <li class="flex items-center gap-2">
                        <svg class="h-4 w-4 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                        Never expires
                    </li>
                    <li class="flex items-center gap-2">
                        <svg class="h-4 w-4 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                        Shareable with friends
                    </li>
                </ul>
                <a href="/contact" class="yoga-btn-secondary w-full text-center">Buy a Pack</a>
            </div>
        </div>

        <!-- Additional info from markdown -->
        @if (_html is not null)
        {
            <div class="max-w-3xl mx-auto">
                <div class="bg-white rounded-2xl shadow-sm border border-base-200 dark:bg-base-900 dark:border-base-700 p-8 md:p-12">
                    <div class="prose prose-base dark:prose-invert max-w-none">
                        @((MarkupString)_html)
                    </div>
                </div>
            </div>
        }
    </div>
</section>

@code {
    private YogaFrontMatter? _fm;
    private string? _html;

    protected override async Task OnInitializedAsync()
    {
        var url = new Uri(Nav.Uri).AbsolutePath;
        var result = await Content.GetRenderedPageAsync<YogaFrontMatter>(url);
        if (result.HasValue)
        {
            _fm = result.Value.FrontMatter;
            _html = result.Value.Html;
        }
    }
}
