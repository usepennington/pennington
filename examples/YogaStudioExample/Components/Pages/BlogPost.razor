@page "/blog/{*Slug:nonfile}"
@inject ContentHelper Content
@inject NavigationManager Nav

@if (_fm is not null && _html is not null)
{
    <PageTitle>@_fm.Title — 937 Yoga</PageTitle>

    <!-- Decorative header band -->
    <div class="h-48 bg-gradient-to-br from-primary-50 via-accent-50 to-primary-100 dark:from-base-900 dark:via-base-950 dark:to-base-900"></div>

    <article class="px-6 -mt-24 pb-16 md:pb-24">
        <div class="max-w-3xl mx-auto">
            <div class="bg-white rounded-2xl shadow-sm border border-base-200 dark:bg-base-900 dark:border-base-700 p-8 md:p-12">
                <a href="/blog" class="inline-flex items-center gap-1 text-sm text-primary-600 hover:text-primary-800 dark:text-primary-400 dark:hover:text-primary-300 mb-8 transition-colors">
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
                    </svg>
                    Back to Blog
                </a>

                <header class="mb-10">
                    <div class="flex flex-wrap gap-2 mb-4">
                        @foreach (var tag in _fm.Tags)
                        {
                            <span class="yoga-tag">@tag</span>
                        }
                    </div>
                    <h1 class="font-display text-4xl md:text-5xl font-bold text-base-900 dark:text-base-50 leading-tight mb-4">
                        @_fm.Title
                    </h1>
                    @if (_fm.Description is not null)
                    {
                        <p class="text-xl text-base-500 dark:text-base-400 leading-relaxed">@_fm.Description</p>
                    }
                    <div class="yoga-blog-meta mt-6 pt-6 border-t border-base-200 dark:border-base-700">
                        @if (_fm.Author is not null)
                        {
                            <span class="font-medium text-base-900 dark:text-base-100">@_fm.Author</span>
                        }
                        @if (_fm.Date.HasValue)
                        {
                            <span>&middot;</span>
                            <time datetime="@_fm.Date.Value.ToString("yyyy-MM-dd")">@_fm.Date.Value.ToString("MMMM d, yyyy")</time>
                        }
                        @if (_fm.ReadingTimeMinutes > 0)
                        {
                            <span>&middot;</span>
                            <span>@_fm.ReadingTimeMinutes min read</span>
                        }
                    </div>
                </header>

                <div class="prose prose-base dark:prose-invert max-w-none">
                    @((MarkupString)_html)
                </div>
            </div>
        </div>
    </article>
}
else
{
    <section class="yoga-section text-center">
        <h1 class="font-display text-3xl font-bold text-base-900 dark:text-base-50 mb-4">Post Not Found</h1>
        <a href="/blog" class="yoga-btn-primary">Back to Blog</a>
    </section>
}

@code {
    [Parameter] public string Slug { get; set; } = "";

    private YogaBlogFrontMatter? _fm;
    private string? _html;

    protected override async Task OnInitializedAsync()
    {
        var uri = new Uri(Nav.Uri);
        var url = uri.AbsolutePath;
        var result = await Content.GetRenderedPageAsync<YogaBlogFrontMatter>(url);
        if (result.HasValue)
        {
            _fm = result.Value.FrontMatter;
            _html = result.Value.Html;
        }
    }
}
