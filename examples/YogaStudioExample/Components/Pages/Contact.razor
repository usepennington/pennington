@page "/contact"
@inject ContentHelper Content
@inject NavigationManager Nav

<PageTitle>Contact — 937 Yoga</PageTitle>

<section class="yoga-section">
    <div class="yoga-container">
        <div class="text-center mb-12">
            <h1 class="font-display text-4xl md:text-5xl font-bold text-base-900 dark:text-base-50 mb-4">Get in Touch</h1>
            <p class="text-base-500 dark:text-base-400 max-w-xl mx-auto">We'd love to hear from you. Drop by, call, or send us a message.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto mb-16">
            <div class="yoga-card">
                <div class="yoga-card-body text-center">
                    <div class="w-12 h-12 mx-auto rounded-full bg-primary-100 dark:bg-primary-900 flex items-center justify-center mb-4">
                        <svg class="h-5 w-5 text-primary-700 dark:text-primary-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                        </svg>
                    </div>
                    <h3 class="font-semibold text-base-900 dark:text-base-100 mb-2">Visit Us</h3>
                    <p class="text-sm text-base-600 dark:text-base-300">937 Elm Street</p>
                    <p class="text-sm text-base-600 dark:text-base-300">Portland, OR 97205</p>
                </div>
            </div>

            <div class="yoga-card">
                <div class="yoga-card-body text-center">
                    <div class="w-12 h-12 mx-auto rounded-full bg-primary-100 dark:bg-primary-900 flex items-center justify-center mb-4">
                        <svg class="h-5 w-5 text-primary-700 dark:text-primary-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                        </svg>
                    </div>
                    <h3 class="font-semibold text-base-900 dark:text-base-100 mb-2">Call Us</h3>
                    <a href="tel:+15035551937" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">(503) 555-1937</a>
                </div>
            </div>

            <div class="yoga-card">
                <div class="yoga-card-body text-center">
                    <div class="w-12 h-12 mx-auto rounded-full bg-primary-100 dark:bg-primary-900 flex items-center justify-center mb-4">
                        <svg class="h-5 w-5 text-primary-700 dark:text-primary-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                        </svg>
                    </div>
                    <h3 class="font-semibold text-base-900 dark:text-base-100 mb-2">Email</h3>
                    <a href="mailto:hello@937yoga.com" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">hello@937yoga.com</a>
                </div>
            </div>
        </div>

        <!-- Studio Hours -->
        <div class="max-w-2xl mx-auto mb-16">
            <h2 class="font-display text-2xl font-bold text-base-900 dark:text-base-50 mb-6 text-center">Studio Hours</h2>
            <div class="yoga-card">
                <div class="yoga-card-body divide-y divide-base-200 dark:divide-base-700">
                    <div class="flex justify-between py-3"><span class="text-base-600 dark:text-base-300">Monday – Friday</span><span class="font-medium text-base-900 dark:text-base-100">6:00 AM – 9:00 PM</span></div>
                    <div class="flex justify-between py-3"><span class="text-base-600 dark:text-base-300">Saturday</span><span class="font-medium text-base-900 dark:text-base-100">8:00 AM – 6:00 PM</span></div>
                    <div class="flex justify-between py-3"><span class="text-base-600 dark:text-base-300">Sunday</span><span class="font-medium text-base-900 dark:text-base-100">9:00 AM – 5:00 PM</span></div>
                </div>
            </div>
        </div>

        <!-- Additional content from markdown -->
        @if (_html is not null)
        {
            <div class="max-w-3xl mx-auto">
                <div class="bg-white rounded-2xl shadow-sm border border-base-200 dark:bg-base-900 dark:border-base-700 p-8 md:p-12">
                    <div class="prose prose-base dark:prose-invert max-w-none">
                        @((MarkupString)_html)
                    </div>
                </div>
            </div>
        }
    </div>
</section>

@code {
    private string? _html;

    protected override async Task OnInitializedAsync()
    {
        var url = new Uri(Nav.Uri).AbsolutePath;
        var result = await Content.GetStaticPageAsync(url);
        if (result.HasValue)
        {
            _html = result.Value.Html;
        }
    }
}
