<article>
    @if (!string.IsNullOrEmpty(Title))
    {
        <header class="mb-8">
            <h1 class="font-display text-4xl md:text-5xl font-bold text-base-900 dark:text-base-50 leading-tight mb-4">@Title</h1>
            @if (!string.IsNullOrEmpty(Author) || Date.HasValue)
            {
                <div class="yoga-blog-meta">
                    @if (!string.IsNullOrEmpty(Author))
                    {
                        <span class="font-medium text-base-900 dark:text-base-100">@Author</span>
                    }
                    @if (Date.HasValue)
                    {
                        <span>&middot;</span>
                        <time datetime="@Date.Value.ToString("yyyy-MM-dd")">@Date.Value.ToString("MMMM d, yyyy")</time>
                    }
                </div>
            }
        </header>
    }

    <div class="prose prose-base dark:prose-invert max-w-none">
        @((MarkupString)(HtmlContent ?? ""))
    </div>
</article>

@code {
    [Parameter] public string? Title { get; set; }
    [Parameter] public string? HtmlContent { get; set; }
    [Parameter] public string? Author { get; set; }
    [Parameter] public DateTime? Date { get; set; }
}
