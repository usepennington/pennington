@* TagIndex — multi-valued (every talk's `tags:` array contributes one entry per tag). *@
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Tags</title>
    <link rel="stylesheet" href="/styles.css" />
</head>
<body class="bg-base-50 text-base-900 dark:bg-base-950 dark:text-base-50">
    <main class="mx-auto max-w-2xl px-6 py-12">
        <p class="text-sm"><a class="text-primary-600 underline" href="/">Home</a></p>
        <h1 class="mt-2 font-display text-3xl font-bold">Browse by tag</h1>

        <ul class="mt-8 flex flex-wrap gap-2">
            @foreach (var term in Terms)
            {
                <li>
                    <a href="@term.Url"
                       class="inline-flex items-baseline gap-1 rounded-full border border-base-200 px-3 py-1 text-sm hover:border-primary-400 dark:border-base-800">
                        <span>@term.Label</span>
                        <span class="text-xs text-base-500">(@term.Items.Count)</span>
                    </a>
                </li>
            }
        </ul>
    </main>
</body>
</html>

@code {
    [Parameter] public ImmutableList<TaxonomyTerm<TalkFrontMatter, string>> Terms { get; set; }
        = ImmutableList<TaxonomyTerm<TalkFrontMatter, string>>.Empty;
}
