@* TagTerm — every talk that carries this tag in its `tags:` array. *@
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Tag: @Term.Label</title>
    <link rel="stylesheet" href="/styles.css" />
</head>
<body class="bg-base-50 text-base-900 dark:bg-base-950 dark:text-base-50">
    <main class="mx-auto max-w-2xl px-6 py-12">
        <p class="text-sm"><a class="text-primary-600 underline" href="/tag/">All tags</a></p>
        <h1 class="mt-2 font-display text-3xl font-bold">Tag: @Term.Label</h1>
        <p class="mt-1 text-base-500">@Term.Items.Count talk@(Term.Items.Count == 1 ? "" : "s")</p>

        <ul class="mt-8 space-y-4">
            @foreach (var item in Term.Items)
            {
                <li class="border-b border-base-100 pb-4 dark:border-base-900">
                    <a href="@item.Url" class="font-medium text-primary-600 underline">@item.FrontMatter.Title</a>
                    <p class="mt-1 text-sm text-base-700 dark:text-base-300">@item.FrontMatter.Description</p>
                    <p class="mt-1 text-xs text-base-500">@item.FrontMatter.Speaker &middot; @item.FrontMatter.Time</p>
                </li>
            }
        </ul>
    </main>
</body>
</html>

@code {
    [Parameter] public TaxonomyTerm<TalkFrontMatter, string> Term { get; set; } = null!;
}
