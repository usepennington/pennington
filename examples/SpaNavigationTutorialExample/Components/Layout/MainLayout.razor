@using Penn.Navigation
@using Penn.Content
@using System.Collections.Immutable
@inherits LayoutComponentBase
@inject IEnumerable<IContentService> ContentServices
@inject NavigationBuilder NavigationBuilder
@inject NavigationManager NavigationManager
@inject PennOptions PennOptions

<div class="min-h-screen flex flex-col">
    <header class="border-b border-neutral-200 bg-white px-6 py-3 flex items-center gap-4">
        <a href="/" class="text-lg font-bold text-neutral-900 hover:text-neutral-700 transition">
            @PennOptions.SiteTitle
        </a>
        <span class="text-neutral-400 text-sm">SPA Navigation Demo</span>
    </header>

    <div class="flex flex-1">
        <nav class="w-64 border-r border-neutral-200 bg-neutral-50 flex-shrink-0">
            <div class="sticky top-0 h-screen overflow-y-auto p-6" data-spa-island="nav" data-spa-loading="keep">
                <TableOfContentsNavigation TableOfContents="@_tableOfContents" />
            </div>
        </nav>

        <div class="flex-1 min-w-0 p-6 lg:p-10">
            <article data-spa-island="article" data-spa-loading="skeleton">
                @Body
            </article>

            <template data-spa-skeleton-for="article">
                <div class="animate-pulse space-y-4">
                    <div class="h-8 bg-neutral-200 rounded w-3/4"></div>
                    <div class="h-4 bg-neutral-200 rounded w-full"></div>
                    <div class="h-4 bg-neutral-200 rounded w-5/6"></div>
                    <div class="h-4 bg-neutral-200 rounded w-4/6"></div>
                </div>
            </template>
        </div>
    </div>
</div>

@code {
    private ImmutableList<NavigationTreeItem>? _tableOfContents;

    protected override async Task OnInitializedAsync()
    {
        var currentPath = NavigationManager.ToAbsoluteUri(NavigationManager.Uri).AbsolutePath;
        var currentRoute = new ContentRoute
        {
            CanonicalPath = new UrlPath(currentPath),
            OutputFile = new FilePath($"{currentPath.TrimStart('/')}/index.html")
        };

        var tocItems = new List<ContentTocItem>();
        foreach (var service in ContentServices)
        {
            var items = await service.GetContentTocEntriesAsync();
            tocItems.AddRange(items);
        }

        _tableOfContents = NavigationBuilder.BuildTree(tocItems, currentRoute);
    }
}
