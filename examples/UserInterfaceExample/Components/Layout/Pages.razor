@page "/{*fileName:nonfile}"

@inject PennOptions PennOptions
@inject ContentHelper ContentHelper

@if (_frontMatter == null || _html == null)
{
    <PageTitle>@PennOptions.SiteTitle</PageTitle>
    <div class="flex justify-center items-center h-64">
        <p class="text-neutral-500">Not found</p>
    </div>
    return;
}

<PageTitle>@PennOptions.SiteTitle - @_frontMatter.Title</PageTitle>

<div class="flex">
    <!-- Content Column -->
    <div class="flex-1 min-w-0">
        <article class="p-8 max-w-4xl">
            <header>
                <h1 class="text-2xl"> @_frontMatter.Title</h1>
            </header>

            <div class="prose prose-neutral max-w-none">
                @((MarkupString)_html)
            </div>
        </article>
    </div>

    <!-- Outline Column -->
    <div class="w-64 flex-shrink-0">
        <aside class="sticky top-0 h-screen overflow-y-auto p-6">
            @if (_outline != null && _frontMatter != null)
            {
                <OutlineNavigation ContentSelector="article" />
            }
        </aside>
    </div>
</div>

@code {
    private DocsFrontMatter? _frontMatter;
    private string? _html;
    private OutlineEntry[]? _outline;

    [Parameter] public required string FileName { get; init; } = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var fileName = FileName;
        if (string.IsNullOrWhiteSpace(fileName))
        {
            fileName = "index";
        }

        var page = await ContentHelper.GetPageByUrlAsync(fileName);
        if (page == null)
        {
            return;
        }

        _outline = page.Value.Outline;
        _frontMatter = page.Value.FrontMatter;
        _html = page.Value.Html;
    }
}
