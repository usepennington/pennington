@if (Items != null && Items.Any())
{
    <nav class="transition-all flex items-center text-xs md:text-sm text-base-600 dark:text-base-400 mb-4">
        @foreach (var (breadcrumb, index) in Items.Select((b, i) => (b, i)))
        {
            @if (index > 0)
            {
                <svg class="w-4 h-4 mx-1 lg:mx-2" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
            }

            @if (breadcrumb == Items.Last())
            {
                <span class="text-base-900 dark:text-base-100 text-pretty">@breadcrumb.Title</span>
            }
            else if (breadcrumb.Route == null || breadcrumb.Route.CanonicalPath.Value == "")
            {
                <span class="text-pretty">@breadcrumb.Title</span>
            }
            else
            {
                <a href="@breadcrumb.Route.NavigationPath.Value" class="hover:text-base-900 dark:hover:text-base-100 transition-colors text-pretty">@breadcrumb.Title</a>
            }
        }
    </nav>
}

@code {
    [Parameter]
    public ImmutableList<BreadcrumbItem>? Items { get; set; }
}
