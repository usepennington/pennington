@* Catch-all that matches every URL and asks the Pennington pipeline to
   resolve it to a markdown file. Unchanged from the styling tutorial — the
   navigation menu lives in MainLayout, so it wraps this page automatically. *@

@page "/{*Path}"
@inject IPageResolver Resolver

@if (_html is not null)
{
    <PageTitle>@_title</PageTitle>
    <h1 class="text-3xl font-bold text-base-900 mb-4">@_title</h1>
    @((MarkupString)_html)
}
else
{
    <PageTitle>Not found</PageTitle>
    <p>No content matches @Path.</p>
}

@code {
    [Parameter] public string? Path { get; set; }

    private string? _title;
    private string? _html;

    protected override async Task OnInitializedAsync()
    {
        var requested = new UrlPath(Path ?? string.Empty).EnsureLeadingSlash();

        if (await Resolver.ResolveAsync(requested) is { } page)
        {
            _title = page.Metadata.Title;
            _html = page.Content.Html;
        }
    }
}
