@* Animated "Hub & Spokes" build-pipeline hero: raw content -> one ASP.NET server -> live dev + static deploy. *@

<div class="rounded-2xl overflow-hidden ring-1 ring-base-200 dark:ring-base-800 bg-base-950 shadow-xl shadow-primary-600/5">
    <div id="ph-root">
        <div class="ph-wrap">
            <div class="ph-stage">

                @* input runway rail (width tracks --rw, set by the scaler) *@
                <div class="ph-rail absolute" style="left:26px;top:299px;height:2px;width:444px;background:linear-gradient(90deg, transparent, var(--color-primary-700));opacity:.9"></div>

                @* content source label — accent marks the pipeline's origin, rhyming with the dev/deploy node dots *@
                <div class="absolute" style="left:26px;top:150px">
                    <span class="inline-flex items-center gap-2 font-mono font-semibold uppercase text-accent-400" style="font-size:10.5px;letter-spacing:.14em">
                        <span class="rounded-full bg-accent-400" style="width:7px;height:7px;box-shadow:0 0 10px var(--color-accent-400)"></span>
                        Your content
                    </span>
                    <div class="font-mono text-base-500" style="font-size:10px;margin-top:4px">/content</div>
                </div>

                @* streaming file cards (all six rendered; the scaler caps how many show + staggers them) *@
                @foreach (var (file, i) in _sourceFiles.Select((f, idx) => (f, idx)))
                {
                    <div class="ph-file" style="left:470px">
                        <div class="flex items-center gap-2 rounded-lg bg-base-800 border border-base-700" style="width:150px;padding:8px 11px;box-shadow:0 6px 18px -10px rgba(0,0,0,.7)">
                            <span class="flex items-center justify-center rounded-md font-mono font-bold text-base-950 @file.Type.BadgeBg" style="width:26px;height:26px;font-size:12px">@file.Type.Glyph</span>
                            <span style="min-width:0;line-height:1.15">
                                <span class="block font-mono font-semibold text-base-100 truncate" style="font-size:12.5px">@file.Name</span>
                                <span class="block font-mono uppercase @file.Type.ExtText" style="font-size:9.5px;letter-spacing:.08em;margin-top:1px">.@file.Type.Ext</span>
                            </span>
                        </div>
                    </div>
                }

                @* cluster: server + dev/deploy branches; coords are relative to the cluster origin (moves with --rw) *@
                <div class="ph-cluster absolute" style="left:470px;top:0;width:710px;height:600px">
                    <svg class="absolute" style="inset:0;width:100%;height:100%;pointer-events:none" viewBox="0 0 710 600" preserveAspectRatio="none">
                        <path d="M230,300 C292,300 292,150 350,150" fill="none" stroke="var(--color-accent-four-700)" stroke-width="2" stroke-opacity=".55" />
                        <path d="M230,300 C292,300 292,452 350,452" fill="none" stroke="var(--color-primary-700)" stroke-width="2" stroke-opacity=".55" />
                    </svg>

                    @* server *@
                    <div class="absolute flex flex-col items-center justify-center rounded-2xl border border-primary-800" style="left:0;top:195px;width:230px;height:210px;gap:14px;background:linear-gradient(160deg, var(--color-base-900) 0%, var(--color-base-950) 100%);box-shadow:0 0 0 1px rgba(0,0,0,.4), 0 30px 60px -30px var(--color-primary-950), inset 0 1px 0 rgba(255,255,255,.04)">
                        <div class="relative grid place-items-center" style="width:70px;height:70px">
                            <span class="ph-ring absolute rounded-full border-2 border-primary-500" style="inset:0"></span>
                            <span class="ph-spin absolute rounded-full border-2 border-dashed border-primary-600" style="width:56px;height:56px"></span>
                            <div class="flex items-center" style="gap:4px;height:26px">
                                @for (var b = 0; b < 4; b++)
                                {
                                    <span class="ph-bar bg-primary-400" style="width:5px;height:22px;border-radius:3px;transform-origin:center;animation-delay:@(Inv(b * 0.13))s"></span>
                                }
                            </div>
                        </div>
                        <div class="text-center">
                            <div class="font-semibold text-base-100" style="font-size:15px;letter-spacing:-.01em">Pennington Server</div>
                            <div class="font-mono text-base-500" style="font-size:10px;margin-top:3px;letter-spacing:.06em">ASP.NET &middot; Kestrel</div>
                        </div>
                        <span class="font-mono text-primary-300 bg-primary-950 border border-primary-800 rounded-full" style="font-size:11px;padding:3px 10px">dotnet run</span>
                    </div>
                    <div class="absolute text-center" style="left:0;top:416px;width:230px">
                        <span class="font-mono text-base-500" style="font-size:9.5px;letter-spacing:.08em">one server &middot; two outputs</span>
                    </div>

                    @* packets traveling the two branch curves *@
                    @for (var i = 0; i < 3; i++)
                    {
                        <span class="ph-devPkt" style="animation-delay:@(Inv(-i * 0.87))s">
                            <span class="block rounded-full bg-accent-four-400" style="width:7px;height:7px;margin-left:-3.5px;margin-top:-3.5px;box-shadow:0 0 10px var(--color-accent-four-400)"></span>
                        </span>
                    }
                    @for (var i = 0; i < 2; i++)
                    {
                        <span class="ph-htmlOut" style="animation-delay:@(Inv(-i * 1.7))s">
                            <span class="flex items-center bg-base-800 border border-primary-700 rounded-md" style="gap:6px;margin-left:-14px;margin-top:-12px;padding:4px 8px;box-shadow:0 6px 16px -8px #000">
                                <span class="grid place-items-center rounded bg-primary-500 font-mono font-extrabold text-base-950" style="width:14px;height:14px;font-size:8px">&lt;&gt;</span>
                                <span class="font-mono text-base-100" style="font-size:10px">.html</span>
                            </span>
                        </span>
                    }

                    @* development branch *@
                    <div class="absolute" style="left:350px;top:60px">
                        <div class="flex items-center" style="gap:10px;margin-bottom:10px">
                            <span class="inline-flex items-center gap-2 font-mono font-semibold uppercase text-accent-four-400" style="font-size:10.5px;letter-spacing:.14em">
                                <span class="rounded-full bg-accent-four-400" style="width:7px;height:7px;box-shadow:0 0 10px var(--color-accent-four-400)"></span>
                                Development
                            </span>
                            <span class="font-mono text-base-500" style="font-size:9.5px">interactive &middot; hot reload</span>
                        </div>
                        <div class="rounded-xl bg-base-900 border border-base-700 overflow-hidden" style="width:300px;box-shadow:0 30px 60px -30px #000">
                            <div class="flex items-center border-b border-base-800" style="gap:7px;padding:9px 12px">
                                <span class="flex" style="gap:5px">
                                    <span class="rounded-full bg-accent-one-500/80" style="width:9px;height:9px"></span>
                                    <span class="rounded-full bg-accent-two-500/80" style="width:9px;height:9px"></span>
                                    <span class="rounded-full bg-accent-three-500/80" style="width:9px;height:9px"></span>
                                </span>
                                <span class="flex items-center bg-base-950 border border-base-800 rounded font-mono text-base-500" style="flex:1;height:16px;padding:0 8px;font-size:9px">localhost:5000</span>
                                <svg class="ph-reload" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent-four-400)" stroke-width="2.4"><path d="M21 12a9 9 0 1 1-3-6.7" /><path d="M21 3v5h-5" /></svg>
                            </div>
                            <div style="padding:0 12px 12px">
                                <div class="rounded bg-primary-600" style="height:22px;opacity:.9;margin-bottom:9px;width:62%"></div>
                                <div class="ph-pvline" style="height:7px;border-radius:3px;background:var(--color-base-700);margin-bottom:6px;width:92%"></div>
                                <div class="ph-pvline" style="height:7px;border-radius:3px;background:var(--color-base-700);margin-bottom:6px;width:80%;animation-delay:.15s"></div>
                                <div class="grid place-items-center bg-base-800" style="height:42px;border-radius:6px;border:1px dashed var(--color-base-700);margin:9px 0">
                                    <span class="font-mono text-base-500" style="font-size:9px">hero.png</span>
                                </div>
                                <div class="ph-pvline" style="height:7px;border-radius:3px;background:var(--color-base-700);margin-bottom:6px;width:88%;animation-delay:.3s"></div>
                                <div class="ph-pvline" style="height:7px;border-radius:3px;background:var(--color-base-700);width:54%;animation-delay:.45s"></div>
                            </div>
                        </div>
                    </div>

                    @* deployment branch *@
                    <div class="absolute" style="left:350px;top:388px">
                        <div class="flex items-center" style="gap:10px;margin-bottom:10px">
                            <span class="inline-flex items-center gap-2 font-mono font-semibold uppercase text-primary-400" style="font-size:10.5px;letter-spacing:.14em">
                                <span class="rounded-full bg-primary-400" style="width:7px;height:7px;box-shadow:0 0 10px var(--color-primary-400)"></span>
                                Deployment
                            </span>
                            <span class="font-mono text-base-500" style="font-size:9.5px">static html &middot; shipped</span>
                        </div>
                        <div class="flex items-center" style="gap:18px">
                            <div class="relative" style="width:150px;height:96px">
                                @{
                                    var outFiles = new[] { "index.html", "guide.html", "blog.html", "api.html" };
                                }
                                @for (var i = 0; i < outFiles.Length; i++)
                                {
                                    <div class="absolute flex items-center bg-base-800 border border-base-700 rounded-lg" style="left:@(i * 6)px;top:@(i * 7)px;width:138px;gap:8px;padding:7px 10px;box-shadow:0 8px 18px -10px #000;z-index:@(10 - i);opacity:@(Inv(1 - i * 0.13))">
                                        <span class="grid place-items-center rounded bg-primary-500 font-mono font-extrabold text-base-950" style="width:16px;height:16px;font-size:8px">&lt;&gt;</span>
                                        <span class="font-mono text-base-100" style="font-size:11px">@outFiles[i]</span>
                                    </div>
                                }
                            </div>
                            <svg width="34" height="20" viewBox="0 0 34 20"><path d="M2 10h26m0 0l-7-6m7 6l-7 6" fill="none" stroke="var(--color-primary-500)" stroke-width="2" /></svg>
                            <div class="ph-globe grid place-items-center rounded-full bg-base-900 border border-primary-700" style="width:64px;height:64px">
                                <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary-300)" stroke-width="1.6"><circle cx="12" cy="12" r="9" /><path d="M3 12h18M12 3c2.5 2.5 2.5 15.5 0 18M12 3c-2.5 2.5-2.5 15.5 0 18" /></svg>
                            </div>
                        </div>
                        <div class="font-mono text-base-500" style="font-size:9.5px;margin-top:12px;margin-left:2px">dotnet run -- build &rarr; output</div>
                    </div>
                </div>@* /cluster *@

            </div>
        </div>
    </div>
</div>

<style>
    .ph-wrap { position: relative; width: 100%; aspect-ratio: 1180 / 600; }
    .ph-stage { position: absolute; top: 0; left: 0; width: 1180px; height: 600px; transform-origin: top left; background: radial-gradient(120% 90% at 50% 0%, var(--color-base-900) 0%, var(--color-base-950) 60%); }

    .ph-file { position: absolute; top: 284px; animation: ph-flow 10s linear infinite; will-change: transform, opacity; }
    @@keyframes ph-flow {
        0%   { transform: translateX(calc((var(--rw, 444px) + 160px) * -1)) scale(.92); opacity: 0; }
        12%  { opacity: 1; }
        85%  { opacity: 1; transform: translateX(-30px) scale(1); }
        96%  { opacity: 0; transform: translateX(8px) scale(.7); }
        100% { opacity: 0; }
    }

    .ph-ring { animation: ph-ring 2.2s ease-out infinite; }
    .ph-spin { animation: ph-spin 7s linear infinite; }
    .ph-bar  { animation: ph-bar 1.1s ease-in-out infinite; }
    @@keyframes ph-ring { 0% { transform: scale(.85); opacity: .5; } 100% { transform: scale(1.5); opacity: 0; } }
    @@keyframes ph-spin { to { transform: rotate(360deg); } }
    @@keyframes ph-bar  { 0%, 100% { transform: scaleY(.35); } 50% { transform: scaleY(1); } }

    .ph-devPkt  { position: absolute; offset-path: path('M230,300 C292,300 292,150 350,150'); offset-rotate: 0deg; animation: ph-devPkt 2.6s linear infinite; }
    .ph-htmlOut { position: absolute; offset-path: path('M230,300 C292,300 292,452 350,452'); offset-rotate: 0deg; animation: ph-shipPkt 3.4s ease-in infinite; will-change: offset-distance; }
    @@keyframes ph-devPkt  { 0% { offset-distance: 0%; opacity: 0; } 8% { opacity: 1; } 92% { opacity: 1; } 100% { offset-distance: 100%; opacity: 0; } }
    @@keyframes ph-shipPkt { 0% { offset-distance: 0%; opacity: 0; } 8% { opacity: 1; } 86% { opacity: 1; } 100% { offset-distance: 100%; opacity: 0; } }

    .ph-pvline { animation: ph-pv 4.2s ease-in-out infinite; }
    @@keyframes ph-pv { 0%, 70% { background: var(--color-base-700); } 80% { background: var(--color-accent-four-500); } 100% { background: var(--color-base-700); } }

    .ph-reload { animation: ph-reload 4.2s ease-in-out infinite; transform-origin: center; }
    @@keyframes ph-reload { 0%, 82% { transform: rotate(0); opacity: .5; } 90% { opacity: 1; } 100% { transform: rotate(360deg); opacity: .5; } }

    .ph-globe { animation: ph-ship 3.4s ease-out infinite; }
    @@keyframes ph-ship { 0%, 100% { box-shadow: 0 0 0 0 color-mix(in oklch, var(--color-primary-500) 60%, transparent); } 50% { box-shadow: 0 0 0 8px color-mix(in oklch, var(--color-primary-500) 0%, transparent); } }

    @@media (prefers-reduced-motion: reduce) {
        .ph-stage .ph-file { animation: none; opacity: 1; }
        .ph-devPkt, .ph-htmlOut { display: none; }
        .ph-ring, .ph-spin, .ph-bar, .ph-pvline, .ph-reload, .ph-globe { animation: none; }
    }
</style>

<script>
    (function () {
        var root = document.getElementById('ph-root');
        if (!root) return;
        var wrap = root.querySelector('.ph-wrap');
        var stage = root.querySelector('.ph-stage');
        if (!wrap || !stage) return;
        var rail = root.querySelector('.ph-rail');
        var cluster = root.querySelector('.ph-cluster');
        var files = Array.prototype.slice.call(root.querySelectorAll('.ph-file'));

        function layoutForWidth(w) {
            var rw, cap;
            if (560 > w) { rw = 90; cap = 1; }
            else if (760 > w) { rw = 180; cap = 2; }
            else if (1000 > w) { rw = 300; cap = 3; }
            else { rw = 444; cap = 4; }
            return { rw: rw, cap: cap, serverX: 26 + rw, stageW: 26 + rw + 710 };
        }

        function fit() {
            var w = wrap.clientWidth;
            if (!w) return;
            var L = layoutForWidth(w);
            var s = w / L.stageW;
            stage.style.width = L.stageW + 'px';
            stage.style.transform = 'scale(' + s + ')';
            wrap.style.height = (600 * s) + 'px';
            wrap.style.setProperty('--rw', L.rw + 'px');
            if (rail) rail.style.width = Math.max(0, L.serverX - 26) + 'px';
            if (cluster) cluster.style.left = L.serverX + 'px';

            var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
            var step = 10 / L.cap;
            files.forEach(function (el, i) {
                if (i >= L.cap) { el.hidden = true; return; }
                el.hidden = false;
                if (reduce) {
                    el.style.animation = 'none';
                    el.style.opacity = '1';
                    el.style.transform = 'none';
                    el.style.left = (26 + (L.rw * i) / L.cap) + 'px';
                } else {
                    el.style.animation = '';
                    el.style.opacity = '';
                    el.style.transform = '';
                    el.style.left = L.serverX + 'px';
                    el.style.animationDelay = '-' + (i * step).toFixed(2) + 's';
                }
            });
        }

        fit();
        if (window.ResizeObserver) {
            new ResizeObserver(fit).observe(wrap);
        } else {
            window.addEventListener('resize', fit);
        }
    })();
</script>

@code {
    private static string Inv(double d) => d.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);

    private record FileType(string Ext, string Glyph, string BadgeBg, string ExtText);
    private record SourceFile(string Name, FileType Type);

    private static readonly FileType Md = new("md", "M↓", "bg-accent-four-400", "text-accent-four-400");
    private static readonly FileType Razor = new("razor", "@", "bg-accent-400", "text-accent-400");
    private static readonly FileType Png = new("png", "▣", "bg-accent-three-400", "text-accent-three-400");
    private static readonly FileType Json = new("json", "{}", "bg-accent-two-400", "text-accent-two-400");
    private static readonly FileType Css = new("css", "#", "bg-accent-one-400", "text-accent-one-400");

    private static readonly SourceFile[] _sourceFiles =
    [
        new("index.md", Md),
        new("Layout.razor", Razor),
        new("hero.png", Png),
        new("site.json", Json),
        new("theme.css", Css),
        new("guide.md", Md),
    ];
}
