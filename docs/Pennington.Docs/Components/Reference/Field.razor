@* One reference entry. Name is rendered in monospace, the metadata row shows
   Type, an optional "required" badge, and an optional Default value, and the
   body carries markdown-rendered prose description. Mirrors ApiDefinitionRow
   for visual consistency with auto-generated API reference pages. *@

<div class="grid grid-cols-1 sm:grid-cols-[14rem_1fr] gap-x-8 gap-y-2 py-4">
    <dt>
        <code class="font-mono text-sm bg-base-100 dark:bg-base-800 text-base-900 dark:text-base-100 rounded px-1.5 py-0.5">@Name</code>
    </dt>
    <dd class="space-y-2 min-w-0">
        @if (HasMetadata)
        {
            <div class="flex flex-wrap items-center gap-2 text-sm text-base-600 dark:text-base-400">
                @if (Required)
                {
                    <span class="inline-block rounded bg-accent-one-100 dark:bg-accent-one-900/40 text-accent-one-700 dark:text-accent-one-300 text-xs font-semibold uppercase tracking-wide px-1.5 py-0.5">required</span>
                }
                @if (!string.IsNullOrWhiteSpace(Type))
                {
                    <code class="font-mono bg-base-100 dark:bg-base-800 rounded px-1.5 py-0.5 break-all">@Type</code>
                }
                @if (!string.IsNullOrWhiteSpace(Default))
                {
                    <span>Default: <code class="font-mono bg-base-100 dark:bg-base-800 rounded px-1.5 py-0.5">@Default</code></span>
                }
            </div>
        }
        @if (ChildContent is not null)
        {
            <div class="prose prose-sm dark:prose-invert max-w-none">@ChildContent</div>
        }
    </dd>
</div>

@code {
    [Parameter, EditorRequired] public string Name { get; set; } = string.Empty;
    [Parameter] public string? Type { get; set; }
    [Parameter] public bool Required { get; set; }
    [Parameter] public string? Default { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private bool HasMetadata =>
        Required || !string.IsNullOrWhiteSpace(Type) || !string.IsNullOrWhiteSpace(Default);
}
