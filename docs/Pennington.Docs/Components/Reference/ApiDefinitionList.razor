<dl class="not-prose divide-y divide-base-200 dark:divide-base-800">
    @foreach (var row in Rows)
    {
        <div class="grid grid-cols-1 sm:grid-cols-[14rem_1fr] gap-x-8 gap-y-2 py-4">
            <dt>
                <code class="font-mono text-sm bg-base-100 dark:bg-base-800 text-base-900 dark:text-base-100 rounded px-1.5 py-0.5">@row.Name</code>
            </dt>
            <dd class="space-y-2 min-w-0">
                <div class="flex flex-wrap items-center gap-2 text-sm text-base-600 dark:text-base-400">
                    @if (row.Required)
                    {
                        <span class="inline-block rounded bg-accent-one-100 dark:bg-accent-one-900/40 text-accent-one-700 dark:text-accent-one-300 text-xs font-semibold uppercase tracking-wide px-1.5 py-0.5">required</span>
                    }
                    <code class="font-mono bg-base-100 dark:bg-base-800 rounded px-1.5 py-0.5 break-all">@row.TypeDisplay</code>
                    @if (row.DefaultValue is not null)
                    {
                        <span>Default: <code class="font-mono bg-base-100 dark:bg-base-800 rounded px-1.5 py-0.5">@row.DefaultValue</code></span>
                    }
                </div>
                @if (!string.IsNullOrEmpty(row.DescriptionHtml))
                {
                    <div class="prose prose-sm dark:prose-invert max-w-none">@((MarkupString)row.DescriptionHtml)</div>
                }
            </dd>
        </div>
    }
</dl>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<ApiDefinitionRow> Rows { get; set; } = [];
}
