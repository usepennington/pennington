@* Container for hand-authored <Field> rows. Emits the same DOM/CSS as
   <ApiDefinitionList> so auto-generated and hand-authored reference lists
   look identical. Optional Title renders a small uppercase section label. *@

@if (!string.IsNullOrWhiteSpace(Title))
{
    <h3 class="not-prose text-xs font-semibold uppercase tracking-wide text-base-500 dark:text-base-400 mt-8 mb-2">@Title</h3>
}
<dl class="not-prose divide-y divide-base-200 dark:divide-base-800">
    @ChildContent
</dl>

@code {
    [Parameter] public string? Title { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
}
