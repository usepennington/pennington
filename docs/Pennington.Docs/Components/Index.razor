@code {
    private record QuickstartStep(string Number, string Title, string Command, string CommandHtml);

    private static readonly QuickstartStep[] _quickstartSteps =
    [
        new("1", "Install the project templates",
            "dotnet new install Pennington.Templates",
            """ dotnet new install <span class="text-primary-500">Pennington.Templates</span>"""),
        new("2", "Scaffold a new docs site",
            "dotnet new pennington-docs -o my-site",
            """ dotnet new <span class="text-primary-500">pennington-docs</span> -o my-site"""),
        new("3", "Run it, write Markdown, watch it update",
            "cd my-site && dotnet run",
            """ cd my-site &amp;&amp; <span class="text-primary-500">dotnet run</span>"""),
    ];
}
