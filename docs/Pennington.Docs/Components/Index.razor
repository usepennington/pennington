@page "/"
@layout Pennington.DocSite.Components.Layout.FullWidthLayout
@using Pennington.UI.Components
@using Microsoft.AspNetCore.Components.Web

<PageTitle>Pennington</PageTitle>

<section class="pt-8 pb-10 lg:pt-14 lg:pb-14">
    <p class="text-xs font-display font-semibold tracking-widest uppercase text-primary-600 dark:text-primary-400 mb-5">A static content engine for .NET</p>
    <h1 class="font-display text-4xl lg:text-6xl font-bold tracking-tight text-base-900 dark:text-base-50 leading-[1.05] mb-6 text-balance">
        A doc site your .NET project deserves.<br />
        <span class="text-primary-600 dark:text-primary-400">Without leaving the SDK.</span>
    </h1>
    <p class="text-base lg:text-lg text-base-600 dark:text-base-400 max-w-2xl mb-8 leading-relaxed">
        Markdown in, static site out. No Node, no npm, no YAML toolchain &mdash; just <code class="font-mono text-sm bg-base-100 dark:bg-base-800 px-1.5 py-0.5 rounded">dotnet run</code>.
        Pennington ships docs at the speed of your build.
    </p>
    <div class="flex flex-wrap items-center gap-3">
        <a href="/tutorials/getting-started/first-site/"
           class="group inline-flex items-center gap-2 font-display font-semibold text-base bg-primary-600 hover:bg-primary-500 text-white rounded-xl px-6 py-3 shadow-lg shadow-primary-600/20 hover:shadow-primary-500/30 transition-all">
            Get Started
            <svg viewBox="0 0 20 20" fill="none" aria-hidden="true" class="h-4 w-4 transition-transform group-hover:translate-x-0.5">
                <path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="m11.5 6.5 3 3.5m0 0-3 3.5m3-3.5h-9"></path>
            </svg>
        </a>
        <a href="https://github.com/usepennington/pennington"
           class="inline-flex items-center gap-2 font-display font-semibold text-base text-base-700 dark:text-base-200 hover:text-primary-700 dark:hover:text-primary-400 rounded-xl px-5 py-3 ring-1 ring-base-300 dark:ring-base-700 hover:ring-primary-500 dark:hover:ring-primary-400 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-4 w-4" stroke="currentColor" fill="none">
                <path d="M10 20.5675C6.57143 21.7248 3.71429 20.5675 2 17" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
                <path d="M10 22V18.7579C10 18.1596 10.1839 17.6396 10.4804 17.1699C10.6838 16.8476 10.5445 16.3904 10.1771 16.2894C7.13394 15.4528 5 14.1077 5 9.64606C5 8.48611 5.38005 7.39556 6.04811 6.4464C6.21437 6.21018 6.29749 6.09208 6.31748 5.9851C6.33746 5.87813 6.30272 5.73852 6.23322 5.45932C5.95038 4.32292 5.96871 3.11619 6.39322 2.02823C6.39322 2.02823 7.27042 1.74242 9.26698 2.98969C9.72282 3.27447 9.95075 3.41686 10.1515 3.44871C10.3522 3.48056 10.6206 3.41384 11.1573 3.28041C11.8913 3.09795 12.6476 3 13.5 3C14.3524 3 15.1087 3.09795 15.8427 3.28041C16.3794 3.41384 16.6478 3.48056 16.8485 3.44871C17.0493 3.41686 17.2772 3.27447 17.733 2.98969C19.7296 1.74242 20.6068 2.02823 20.6068 2.02823C21.0313 3.11619 21.0496 4.32292 20.7668 5.45932C20.6973 5.73852 20.6625 5.87813 20.6825 5.9851C20.7025 6.09207 20.7856 6.21019 20.9519 6.4464C21.6199 7.39556 22 8.48611 22 9.64606C22 14.1077 19.8661 15.4528 16.8229 16.2894C16.4555 16.3904 16.3162 16.8476 16.5196 17.1699C16.8161 17.6396 17 18.1596 17 18.7579V22" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
            View on GitHub
        </a>
    </div>
</section>

<section class="pb-12 lg:pb-16">
    <div class="rounded-2xl overflow-hidden ring-1 ring-base-200 dark:ring-base-800 bg-base-950 shadow-xl shadow-primary-600/5">
        <div class="flex items-center gap-2 px-4 py-3 bg-base-900 border-b border-base-800">
            <span class="w-3 h-3 rounded-full bg-red-500/80" aria-hidden="true"></span>
            <span class="w-3 h-3 rounded-full bg-yellow-500/80" aria-hidden="true"></span>
            <span class="w-3 h-3 rounded-full bg-green-500/80" aria-hidden="true"></span>
            <span class="ml-3 font-mono text-xs text-base-400">my-site &mdash; bash</span>
        </div>
        <div class="p-6 lg:p-8 font-mono text-sm lg:text-base text-base-100 min-h-[320px] lg:min-h-[360px]">
            <div class="terminal-cast space-y-1.5 leading-relaxed">
                <div class="cast-line cast-line-1">
                    <span class="text-primary-400 select-none">$</span> dotnet new install <span class="text-primary-300">Pennington.Templates</span>
                </div>
                <div class="cast-line cast-line-2 text-base-400">The template <span class="text-base-200">"Pennington Doc Site"</span> was installed successfully.</div>
                <div class="cast-line cast-line-3">
                    <span class="text-primary-400 select-none">$</span> dotnet new <span class="text-primary-300">pennington-docs</span> -o my-site
                </div>
                <div class="cast-line cast-line-4 text-base-400">The template <span class="text-base-200">"Pennington Doc Site"</span> was created successfully.</div>
                <div class="cast-line cast-line-5">
                    <span class="text-primary-400 select-none">$</span> cd my-site &amp;&amp; <span class="text-primary-300">dotnet run</span>
                </div>
                <div class="cast-line cast-line-6 pt-2">
                    <span class="text-green-400">info:</span> Microsoft.Hosting.Lifetime[14]
                </div>
                <div class="cast-line cast-line-7 pl-6 text-base-300">
                    Now listening on: <span class="text-primary-300 underline decoration-dotted underline-offset-4">http://localhost:5000</span>
                </div>
                <div class="cast-line cast-line-8 pt-2 text-base-500">
                    &mdash; your site is live. start writing markdown.<span class="cast-cursor text-primary-400">&#9608;</span>
                </div>
            </div>
        </div>
    </div>
    <p class="mt-5 text-sm font-display text-base-500 dark:text-base-400 text-center">
        Zero to site in about 90 seconds. This is the whole video.
    </p>
</section>

<section class="pb-12 lg:pb-16">
    <div class="rounded-2xl border border-base-200 dark:border-base-700/50 bg-base-50 dark:bg-base-900/50 p-6 lg:p-10">
        <div class="grid grid-cols-1 xl:grid-cols-2 gap-8 xl:gap-12">
            <div>
                <p class="text-xs font-display font-semibold tracking-widest uppercase text-primary-600 dark:text-primary-400 mb-4">
                    <span aria-hidden="true" class="mr-1">&mdash;</span> Quickstart
                </p>
                <h2 class="font-display text-3xl font-bold tracking-tight text-base-900 dark:text-base-50 leading-tight mb-4 text-balance">
                    A site you can write to in 90 seconds.
                </h2>
                <p class="text-sm lg:text-base text-base-600 dark:text-base-400 leading-relaxed mb-6">
                    .NET 11. Three commands. Markdown.
                </p>
                <a href="/tutorials/getting-started/first-site/"
                   class="group inline-flex items-center gap-2 font-display font-semibold text-sm text-base-700 dark:text-base-200 hover:text-primary-700 dark:hover:text-primary-400 rounded-xl px-5 py-2.5 ring-1 ring-base-300 dark:ring-base-700 hover:ring-primary-500 dark:hover:ring-primary-400 transition-colors">
                    Walk through the full tutorial
                    <svg viewBox="0 0 20 20" fill="none" aria-hidden="true" class="h-4 w-4 transition-transform group-hover:translate-x-0.5">
                        <path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="m11.5 6.5 3 3.5m0 0-3 3.5m3-3.5h-9"></path>
                    </svg>
                </a>
            </div>
            <div class="flex flex-col gap-3">
                @foreach (var step in _quickstartSteps)
                {
                    <div class="flex items-center gap-4 rounded-xl border border-base-200 dark:border-base-800 bg-white/70 dark:bg-base-950/60 px-4 py-3">
                        <span class="shrink-0 flex items-center justify-center w-7 h-7 rounded-full ring-2 ring-base-300 dark:ring-base-800 bg-base-100 dark:bg-base-900 font-display text-xs font-bold text-primary-600 dark:text-primary-400">
                            @step.Number
                        </span>
                        <div class="min-w-0 flex-1">
                            <p class="text-sm font-display font-medium text-base-900 dark:text-base-100 mb-0.5">@step.Title</p>
                            <div class="font-mono text-xs lg:text-sm text-base-600 dark:text-base-300">
                                <span class="text-primary-500 select-none">$</span>
                                @((MarkupString)step.CommandHtml)
                            </div>
                        </div>
                        <button type="button"
                                onclick="navigator.clipboard.writeText(this.dataset.cmd);this.textContent='Copied';setTimeout(()=>this.textContent='Copy',1200)"
                                data-cmd="@step.Command"
                                class="shrink-0 text-xs font-display font-medium text-base-500 hover:text-primary-600 dark:hover:text-primary-400 transition-colors px-2 py-1">
                            Copy
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

<section class="pb-16 lg:pb-24 pt-4">
    <div class="max-w-3xl">
        <p class="text-xs font-display font-semibold tracking-widest uppercase text-primary-600 dark:text-primary-400 mb-4">
            <span aria-hidden="true" class="mr-1">&mdash;</span> Familiar on purpose
        </p>
        <h2 class="font-display text-3xl lg:text-4xl font-bold tracking-tight text-base-900 dark:text-base-50 leading-tight mb-5 text-balance">
            Pick up where your <span class="text-primary-600 dark:text-primary-400">dotnet</span> habits already are.
        </h2>
        <p class="text-base lg:text-lg text-base-600 dark:text-base-400 leading-relaxed">
            No new CLI to learn, no build tool to babysit. Open the solution, hit <kbd class="inline-flex items-center gap-1 font-mono text-xs bg-base-100 dark:bg-base-800 border border-base-200 dark:border-base-700 rounded px-1.5 py-0.5 text-base-700 dark:text-base-200">F5</kbd>, and you're shipping content.
            Your layouts are Razor components. Your config is a C# record. Your deploy target is whatever you'd deploy an ASP.NET app to.
        </p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mt-10">
        <div class="rounded-xl border border-base-200 dark:border-base-800 bg-base-50 dark:bg-base-900/50 p-5">
            <div class="flex items-center gap-2 font-display text-sm font-semibold text-base-900 dark:text-base-50 mb-2">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-4 w-4 text-primary-600 dark:text-primary-400" fill="none" stroke="currentColor" stroke-width="1.75">
                    <path d="M5 12l5 5L20 7" stroke-linecap="round" stroke-linejoin="round"></path>
                </svg>
                One .csproj
            </div>
            <p class="text-sm text-base-600 dark:text-base-400 leading-relaxed">No <code class="font-mono text-xs bg-base-100 dark:bg-base-800 px-1 rounded">package.json</code>. No <code class="font-mono text-xs bg-base-100 dark:bg-base-800 px-1 rounded">node_modules</code>. Your laptop&rsquo;s battery will notice.</p>
        </div>
        <div class="rounded-xl border border-base-200 dark:border-base-800 bg-base-50 dark:bg-base-900/50 p-5">
            <div class="flex items-center gap-2 font-display text-sm font-semibold text-base-900 dark:text-base-50 mb-2">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-4 w-4 text-primary-600 dark:text-primary-400" fill="none" stroke="currentColor" stroke-width="1.75">
                    <path d="M5 12l5 5L20 7" stroke-linecap="round" stroke-linejoin="round"></path>
                </svg>
                Config in C#
            </div>
            <p class="text-sm text-base-600 dark:text-base-400 leading-relaxed">A POCO with real types. IntelliSense, refactoring, and compile errors instead of silent YAML typos.</p>
        </div>
        <div class="rounded-xl border border-base-200 dark:border-base-800 bg-base-50 dark:bg-base-900/50 p-5">
            <div class="flex items-center gap-2 font-display text-sm font-semibold text-base-900 dark:text-base-50 mb-2">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-4 w-4 text-primary-600 dark:text-primary-400" fill="none" stroke="currentColor" stroke-width="1.75">
                    <path d="M5 12l5 5L20 7" stroke-linecap="round" stroke-linejoin="round"></path>
                </svg>
                Live in dev. Flat in prod.
            </div>
            <p class="text-sm text-base-600 dark:text-base-400 leading-relaxed">Dev mode is a live ASP.NET app with hot reload. Build mode crawls its own routes and writes flat files. Same code, two outputs.</p>
        </div>
    </div>
</section>

<section class="pb-16 lg:pb-24">
    <div class="max-w-3xl mb-10">
        <p class="text-xs font-display font-semibold tracking-widest uppercase text-primary-600 dark:text-primary-400 mb-4">
            <span aria-hidden="true" class="mr-1">&mdash;</span> The dev loop
        </p>
        <h2 class="font-display text-3xl lg:text-4xl font-bold tracking-tight text-base-900 dark:text-base-50 leading-tight mb-5 text-balance">
            Edit. Save. See it.
        </h2>
        <p class="text-base lg:text-lg text-base-600 dark:text-base-400 leading-relaxed">
            Run <code class="font-mono text-sm bg-base-100 dark:bg-base-800 px-1.5 py-0.5 rounded">dotnet run</code> once. Markdown, front matter, navigation, cross-references, and Razor components all hot-reload. The feedback loop is the one you already trust for web apps &mdash; pointed at your content.
        </p>
    </div>
    <div class="relative grid grid-cols-1 lg:grid-cols-2 gap-0 items-stretch rounded-2xl overflow-hidden ring-1 ring-base-200 dark:ring-base-800">
        <div class="bg-base-950 p-6 lg:p-7 font-mono text-sm">
            <div class="flex items-center justify-between mb-3">
                <span class="text-xs font-display font-semibold tracking-widest uppercase text-base-500">Content/index.md</span>
                <span class="text-xs text-base-500">saved &bull; just now</span>
            </div>
            <pre class="text-base-200 whitespace-pre-wrap leading-relaxed"><span class="text-base-500">---
title: Release notes
order: 1
---</span>

## Shipping v1.2

Now with <span class="text-primary-300">&lt;Badge Variant="Success"&gt;faster builds&lt;/Badge&gt;</span>
and a rewritten navigation tree.</pre>
        </div>
        <div class="hidden lg:flex absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 z-10 items-center justify-center h-10 w-10 rounded-full bg-primary-600 text-white shadow-lg shadow-primary-600/30 ring-4 ring-base-100 dark:ring-base-950" aria-hidden="true">
            <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2.25">
                <path d="M5 12h14m0 0l-5-5m5 5l-5 5" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
        </div>
        <div class="bg-white dark:bg-base-900 p-6 lg:p-7 border-t lg:border-t-0 lg:border-l border-base-200 dark:border-base-800 flex flex-col">
            <div class="flex items-center justify-between mb-3">
                <span class="text-xs font-display font-semibold tracking-widest uppercase text-base-500">localhost:5000</span>
                <span class="inline-flex items-center gap-1.5 text-xs font-display text-green-600 dark:text-green-400">
                    <span class="relative flex h-2 w-2">
                        <span class="absolute inline-flex h-full w-full rounded-full bg-green-500 opacity-75 animate-ping"></span>
                        <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
                    </span>
                    live
                </span>
            </div>
            <h3 class="font-display text-xl font-bold text-base-900 dark:text-base-50 mb-3">Shipping v1.2</h3>
            <p class="text-sm text-base-700 dark:text-base-300 leading-relaxed mb-6">
                Now with
                <span class="inline-flex items-center rounded-md bg-green-100 dark:bg-green-900/40 px-2 py-0.5 text-xs font-display font-semibold text-green-700 dark:text-green-300 mx-0.5">faster builds</span>
                and a rewritten navigation tree.
            </p>
            <div class="mt-auto grid grid-cols-3 gap-3 pt-4 border-t border-base-200 dark:border-base-800">
                <div>
                    <p class="text-xs font-display uppercase tracking-widest text-base-500 mb-1">Nav</p>
                    <p class="text-xs text-base-600 dark:text-base-400">Tree rebuilt</p>
                </div>
                <div>
                    <p class="text-xs font-display uppercase tracking-widest text-base-500 mb-1">Search</p>
                    <p class="text-xs text-base-600 dark:text-base-400">Index refreshed</p>
                </div>
                <div>
                    <p class="text-xs font-display uppercase tracking-widest text-base-500 mb-1">Xrefs</p>
                    <p class="text-xs text-base-600 dark:text-base-400">Resolved</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="pb-16 lg:pb-24">
    <div class="max-w-3xl mb-10">
        <p class="text-xs font-display font-semibold tracking-widest uppercase text-primary-600 dark:text-primary-400 mb-4">
            <span aria-hidden="true" class="mr-1">&mdash;</span> Content-first
        </p>
        <h2 class="font-display text-3xl lg:text-4xl font-bold tracking-tight text-base-900 dark:text-base-50 leading-tight mb-5 text-balance">
            The shell stays out of your way.
        </h2>
        <p class="text-base lg:text-lg text-base-600 dark:text-base-400 leading-relaxed">
            Layout, navigation, search, dark mode &mdash; handled. Your attention belongs on the content: Razor components inside markdown, compiler-level C# highlighting, real <code class="font-mono text-sm bg-base-100 dark:bg-base-800 px-1.5 py-0.5 rounded">xmldocid</code> references.
        </p>
    </div>

    <div class="rounded-2xl border border-base-200 dark:border-base-800 bg-base-50 dark:bg-base-900/50 p-6 lg:p-8 mb-6">
        <div class="flex items-start justify-between gap-4 mb-5">
            <div>
                <h3 class="font-display text-xl lg:text-2xl font-bold text-base-900 dark:text-base-50 mb-1.5">Your components. In your markdown.</h3>
                <p class="text-sm text-base-600 dark:text-base-400">Write a Razor component. Drop it in prose. Rendered at build time, no JS bundle required.</p>
            </div>
            <a href="/tutorials/beyond-basics/custom-razor-component/" class="hidden sm:inline-flex shrink-0 items-center gap-1 font-display text-sm font-semibold text-primary-700 dark:text-primary-400 hover:underline whitespace-nowrap">
                Tutorial
                <svg viewBox="0 0 20 20" fill="none" aria-hidden="true" class="h-4 w-4"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="m11.5 6.5 3 3.5m0 0-3 3.5m3-3.5h-9"/></svg>
            </a>
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
            <div class="rounded-xl bg-base-950 p-5 font-mono text-sm overflow-x-auto">
                <div class="text-xs font-display uppercase tracking-widest text-base-500 mb-3">guide.md</div>
<pre class="text-base-200 leading-relaxed"><span class="text-base-500">## API Status</span>

The ingest endpoint is <span class="text-primary-300">&lt;Badge Variant="Warning"&gt;</span>beta<span class="text-primary-300">&lt;/Badge&gt;</span>.
Read the <span class="text-primary-300">&lt;ApiLink Id="T:Ingest.Client" /&gt;</span>
for the current shape.</pre>
            </div>
            <div class="rounded-xl bg-white dark:bg-base-900 border border-base-200 dark:border-base-800 p-5">
                <div class="text-xs font-display uppercase tracking-widest text-base-500 mb-3">rendered</div>
                <h4 class="font-display text-lg font-bold text-base-900 dark:text-base-50 mb-3">API Status</h4>
                <p class="text-sm text-base-700 dark:text-base-300 leading-relaxed">
                    The ingest endpoint is
                    <span class="inline-flex items-center rounded-md bg-amber-100 dark:bg-amber-900/40 px-2 py-0.5 text-xs font-display font-semibold text-amber-700 dark:text-amber-300 mx-0.5">beta</span>.
                    Read the <a href="#" class="font-mono text-sm text-primary-700 dark:text-primary-400 underline decoration-dotted underline-offset-4">Ingest.Client</a> for the current shape.
                </p>
            </div>
        </div>
    </div>

    <div class="rounded-2xl border border-base-200 dark:border-base-800 bg-base-50 dark:bg-base-900/50 p-6 lg:p-8">
        <div class="flex items-start justify-between gap-4 mb-5">
            <div>
                <h3 class="font-display text-xl lg:text-2xl font-bold text-base-900 dark:text-base-50 mb-1.5">Syntax highlighting from the actual compiler.</h3>
                <p class="text-sm text-base-600 dark:text-base-400">Reference a symbol by <code class="font-mono text-xs bg-base-100 dark:bg-base-800 px-1 rounded">xmldocid</code>. Pennington.Roslyn pulls the source and hands it to the real semantic highlighter. Renames don&rsquo;t break your docs.</p>
            </div>
            <a href="/explanation/rendering/highlighting/" class="hidden sm:inline-flex shrink-0 items-center gap-1 font-display text-sm font-semibold text-primary-700 dark:text-primary-400 hover:underline whitespace-nowrap">
                How it works
                <svg viewBox="0 0 20 20" fill="none" aria-hidden="true" class="h-4 w-4"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="m11.5 6.5 3 3.5m0 0-3 3.5m3-3.5h-9"/></svg>
            </a>
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
            <div class="rounded-xl bg-base-950 p-5 font-mono text-sm overflow-x-auto">
                <div class="text-xs font-display uppercase tracking-widest text-base-500 mb-3">writing.md</div>
<pre class="text-base-200 leading-relaxed"><span class="text-base-500">```csharp:xmldocid,bodyonly</span>
M:Pennington.BlogSite.
  BlogSiteServiceExtensions.
  AddBlogSite(IServiceCollection)
<span class="text-base-500">```</span></pre>
            </div>
            <div class="rounded-xl bg-white dark:bg-base-900 border border-base-200 dark:border-base-800 p-0 overflow-hidden">
                <div class="px-5 pt-4 pb-2">
                    <div class="text-xs font-display uppercase tracking-widest text-base-500">rendered</div>
                </div>
<pre class="px-5 pb-5 font-mono text-sm leading-relaxed overflow-x-auto bg-base-50 dark:bg-base-950"><span class="text-rose-700 dark:text-rose-300">services</span>.<span class="text-amber-700 dark:text-amber-300">AddSingleton</span>&lt;<span class="text-amber-700 dark:text-amber-300">IBlogContentService</span>, <span class="text-amber-700 dark:text-amber-300">BlogContentService</span>&gt;();
<span class="text-rose-700 dark:text-rose-300">services</span>.<span class="text-amber-700 dark:text-amber-300">AddSingleton</span>&lt;<span class="text-amber-700 dark:text-amber-300">BlogHomeRouteGenerator</span>&gt;();
<span class="text-rose-700 dark:text-rose-300">services</span>.<span class="text-amber-700 dark:text-amber-300">AddSingleton</span>&lt;<span class="text-amber-700 dark:text-amber-300">BlogArchiveRouteGenerator</span>&gt;();
<span class="text-rose-700 dark:text-rose-300">services</span>.<span class="text-amber-700 dark:text-amber-300">AddSingleton</span>&lt;<span class="text-amber-700 dark:text-amber-300">TagRouteGenerator</span>&gt;();
<span class="text-slate-500 dark:text-slate-400">// &hellip;</span>
<span class="text-sky-700 dark:text-sky-300">return</span> <span class="text-rose-700 dark:text-rose-300">services</span>;</pre>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mt-6">
        <div class="rounded-xl border border-base-200 dark:border-base-800 bg-base-50 dark:bg-base-900/50 p-5">
            <h4 class="font-display font-semibold text-base-900 dark:text-base-50 mb-1">Front matter that types-check</h4>
            <p class="text-sm text-base-600 dark:text-base-400 leading-relaxed">Page metadata is a C# record, not YAML soup. IntelliSense on fields, compile errors instead of runtime surprises.</p>
        </div>
        <div class="rounded-xl border border-base-200 dark:border-base-800 bg-base-50 dark:bg-base-900/50 p-5">
            <h4 class="font-display font-semibold text-base-900 dark:text-base-50 mb-1">Rich Markdown</h4>
            <p class="text-sm text-base-600 dark:text-base-400 leading-relaxed">Tabbed code blocks, Mermaid, alerts, diff highlights, and focus lines. Shipped. Configurable.</p>
        </div>
        <div class="rounded-xl border border-base-200 dark:border-base-800 bg-base-50 dark:bg-base-900/50 p-5">
            <h4 class="font-display font-semibold text-base-900 dark:text-base-50 mb-1">All the boring parts</h4>
            <p class="text-sm text-base-600 dark:text-base-400 leading-relaxed">Search index, RSS, sitemap, llms.txt, structured data, locale routing. All opt-in, all zero-config.</p>
        </div>
    </div>
</section>

