<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net10.0;net11.0</TargetFrameworks>
    <LangVersion>preview</LangVersion>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <Description>Build-time Beck diagram rendering for Pennington — ```beck fences become self-animating inline SVG</Description>
    <PackageTags>dotnet beck diagrams svg documentation</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Pennington.Tests" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Pennington\Pennington.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Beck" />
    <!-- Direct use in BeckCodeBlockPreprocessor.ApplyStyle (also Beck's own runtime dependency). -->
    <PackageReference Include="YamlDotNet" />
  </ItemGroup>
</Project>
