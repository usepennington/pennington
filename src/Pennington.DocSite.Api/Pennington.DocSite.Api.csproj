<Project Sdk="Microsoft.NET.Sdk.Razor">
  <PropertyGroup>
    <TargetFrameworks>net10.0;net11.0</TargetFrameworks>
    <LangVersion>preview</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <Description>API reference Razor components for Pennington DocSite — renders the API-metadata model into browsable type and member pages.</Description>
    <PackageTags>dotnet api-docs documentation-site razor</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Pennington.IntegrationTests" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Pennington.DocSite\Pennington.DocSite.csproj" />
    <ProjectReference Include="..\Pennington.ApiMetadata\Pennington.ApiMetadata.csproj" />
  </ItemGroup>
</Project>
