@inherits ApiReferenceComponentBase

@((MarkupString)_html)

@code {
    [Parameter, EditorRequired] public string XmlDocId { get; set; } = string.Empty;
    [Parameter] public string Kind { get; set; } = "Methods";
    [Parameter] public string Access { get; set; } = "public";
    [Parameter] public string Order { get; set; } = "alphabetical";
    [Parameter] public int HeadingLevel { get; set; } = 3;

    private string _html = string.Empty;

    protected override void OnParametersSet()
    {
        _html = BuildHtml();
    }

    private string BuildHtml()
    {
        if (string.IsNullOrWhiteSpace(XmlDocId))
        {
            return DiagError(MissingAttributeError("ApiMemberList", "XmlDocId"));
        }

        var kind = MemberOptionParser.ParseKind(Kind);
        var access = MemberOptionParser.ParseAccess(Access);
        var order = MemberOptionParser.ParseOrder(Order);

        var result = Fetch("ApiMemberList", XmlDocId, p => p.GetMembersAsync(XmlDocId, kind, access, order));
        if (!result.Ok)
        {
            return DiagError(result.ErrorHtml!);
        }

        var members = result.Value;
        if (members.Length == 0)
        {
            Diagnostics?.AddWarning($"<ApiMemberList> no {Kind.ToLowerInvariant()} matched for {XmlDocId}");
            return $"<p><em>No {WebUtility.HtmlEncode(Kind.ToLowerInvariant())} documented.</em></p>";
        }

        var headingTag = $"h{Math.Clamp(HeadingLevel, 2, 6)}";
        var sb = new StringBuilder();
        foreach (var m in members)
        {
            var id = Slugify(m.Name);
            sb.Append('<').Append(headingTag).Append(" id=\"").Append(id).Append("\">")
                .Append("<code>").Append(WebUtility.HtmlEncode(m.Name)).Append("</code>");
            if (m.IsRequired)
            {
                sb.Append(" <span class=\"api-required\">(required)</span>");
            }
            sb.Append("</").Append(headingTag).Append('>');

            if (!string.IsNullOrEmpty(m.SignatureHtml))
            {
                sb.Append(m.SignatureHtml);
            }

            if (m.Xmldoc.HasSummary)
            {
                sb.Append(Renderer.RenderHtml(m.Xmldoc.Summary));
            }
            else
            {
                Diagnostics?.AddWarning($"Member {m.Uid} has no <summary>");
            }

            if (m.Xmldoc.HasReturns)
            {
                sb.Append("<p><strong>Returns.</strong> ").Append(Renderer.RenderInlineHtml(m.Xmldoc.Returns)).Append("</p>");
            }
        }

        return sb.ToString();
    }

    private static string Slugify(string name)
    {
        var sb = new StringBuilder(name.Length);
        foreach (var ch in name)
        {
            if (char.IsLetterOrDigit(ch))
            {
                sb.Append(char.ToLowerInvariant(ch));
            }
            else if (ch is '-' or '_')
            {
                sb.Append(ch);
            }
            else if (ch is ' ' or '.' or ',')
            {
                sb.Append('-');
            }
        }

        return sb.ToString();
    }
}
