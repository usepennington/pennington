@inherits ApiReferenceComponentBase

@((MarkupString)_html)

@code {
    [Parameter, EditorRequired] public string XmlDocId { get; set; } = string.Empty;

    private string _html = string.Empty;

    protected override void OnParametersSet()
    {
        _html = BuildHtml();
    }

    private string BuildHtml()
    {
        if (string.IsNullOrWhiteSpace(XmlDocId))
        {
            return DiagError(MissingAttributeError("ApiReturns", "XmlDocId"));
        }

        var result = Fetch("ApiReturns", XmlDocId, p => p.GetXmldocAsync(XmlDocId));
        if (!result.Ok)
        {
            return DiagError(result.ErrorHtml!);
        }

        if (!result.Value.HasReturns)
        {
            Diagnostics?.AddWarning($"{XmlDocId} has no <returns>");
            return string.Empty;
        }

        return Renderer.RenderHtml(result.Value.Returns);
    }
}
