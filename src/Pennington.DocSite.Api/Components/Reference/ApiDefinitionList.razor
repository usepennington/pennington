<dl class="not-prose divide-y divide-base-200 dark:divide-base-800">
    @foreach (var row in Rows)
    {
        <div class="grid grid-cols-1 sm:grid-cols-[12rem_1fr] gap-x-6 gap-y-1 py-4">
            <dt class="flex flex-col gap-0.5 min-w-0">
                <code class="font-mono text-sm font-semibold text-base-900 dark:text-base-50 break-words">@row.Name</code>
                <code class="font-mono text-xs text-accent-700 dark:text-accent-400 break-words">@row.TypeDisplay</code>
            </dt>
            <dd class="space-y-2 min-w-0">
                @if (row.Required || row.DefaultValue is not null)
                {
                    <div class="flex flex-wrap items-center gap-2 text-xs text-base-600 dark:text-base-400">
                        @if (row.Required)
                        {
                            <span class="inline-block rounded bg-accent-one-100 dark:bg-accent-one-900/40 text-accent-one-700 dark:text-accent-one-300 font-semibold uppercase tracking-wide px-1.5 py-0.5">required</span>
                        }
                        @if (row.DefaultValue is not null)
                        {
                            <span>Default: <code class="font-mono bg-base-100 dark:bg-base-800 rounded px-1.5 py-0.5">@row.DefaultValue</code></span>
                        }
                    </div>
                }
                @if (!string.IsNullOrEmpty(row.DescriptionHtml))
                {
                    <div class="text-sm text-base-700 dark:text-base-300">@((MarkupString)row.DescriptionHtml)</div>
                }
            </dd>
        </div>
    }
</dl>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<ApiDefinitionRow> Rows { get; set; } = [];
}
