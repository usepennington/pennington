@* Source-authoritative C# dump for llms.txt extraction. Renders the type
   as a declaration-only skeleton — member signatures with xmldoc summaries,
   no method bodies — inside one <pre><code class="language-csharp"> block
   that the HtmlToMarkdownConverter emits as a clean ```csharp fence. *@
@inherits ApiReferenceComponentBase

@if (_detail is not null)
{
    <h1>@_detail.Summary.FullTypeName</h1>

    <pre><code class="language-csharp">@BuildDeclarationsBlock()</code></pre>
}

@code {
    [Parameter, EditorRequired] public string XmlDocId { get; set; } = string.Empty;

    private ApiTypeDetail? _detail;
    private System.Collections.Immutable.ImmutableArray<ApiMember> _members = [];

    protected override void OnParametersSet()
    {
        _detail = null;
        _members = [];

        if (string.IsNullOrWhiteSpace(XmlDocId)) return;

        // Render nothing on failure — this dump feeds llms.txt extraction — but still log via Fetch.
        var typeResult = Fetch("ApiRobotsDump", XmlDocId, p => p.GetTypeAsync(XmlDocId));
        if (!typeResult.Ok) return;

        _detail = typeResult.Value;
        if (_detail is not null)
        {
            var membersResult = Fetch("ApiRobotsDump", XmlDocId,
                p => p.GetMembersAsync(XmlDocId, MemberKind.All, AccessFilter.Public, MemberOrder.Alphabetical));
            if (membersResult.Ok)
            {
                _members = membersResult.Value;
            }
        }
    }

    private MarkupString BuildDeclarationsBlock()
    {
        if (_detail is null) return new MarkupString(string.Empty);

        var sb = new StringBuilder();

        if (!string.IsNullOrEmpty(_detail.Summary.Namespace))
        {
            sb.Append("namespace ").Append(_detail.Summary.Namespace).AppendLine(";");
            sb.AppendLine();
        }

        AppendXmldocSummary(sb, _detail.Xmldoc, indent: "");

        var kindKeyword = KindKeyword(_detail.Summary.Kind);

        // Delegates carry their signature on the type line itself — no body.
        if (_detail.Summary.Kind == ApiTypeKind.Delegate)
        {
            sb.Append("public ").Append(kindKeyword).Append(' ').Append(_detail.Summary.Name).AppendLine(";");
            return new MarkupString(sb.ToString());
        }

        sb.Append("public ").Append(kindKeyword).Append(' ').AppendLine(_detail.Summary.Name);
        sb.AppendLine("{");

        var first = true;
        foreach (var m in _members)
        {
            if (!first) sb.AppendLine();
            first = false;

            AppendXmldocSummary(sb, m.Xmldoc, indent: "    ");

            var sig = (m.SignatureHtml ?? string.Empty).TrimEnd();
            if (sig.Length == 0) continue;

            sb.Append("    ").Append(sig);
            if (!EndsWithBraceOrSemicolon(sig))
            {
                sb.Append(';');
            }
            sb.AppendLine();
        }

        sb.AppendLine("}");
        return new MarkupString(sb.ToString());
    }

    private void AppendXmldocSummary(StringBuilder sb, ParsedXmlDoc xmldoc, string indent)
    {
        if (!xmldoc.HasSummary) return;

        var summaryHtml = Renderer.RenderInlineHtml(xmldoc.Summary).Trim();
        if (summaryHtml.Length == 0) return;

        sb.Append(indent).Append("/// ").AppendLine(summaryHtml);
    }

    private static string KindKeyword(ApiTypeKind kind) => kind switch
    {
        ApiTypeKind.Class => "class",
        ApiTypeKind.Struct => "struct",
        ApiTypeKind.Interface => "interface",
        ApiTypeKind.Enum => "enum",
        ApiTypeKind.Record => "record",
        ApiTypeKind.Delegate => "delegate",
        _ => "class",
    };

    private static bool EndsWithBraceOrSemicolon(string html)
    {
        // SignatureHtml is highlighted with <span> tokens around each lexeme —
        // strip tags before inspecting the final visible character.
        var stripped = System.Text.RegularExpressions.Regex.Replace(html, @"<[^>]+>", "").TrimEnd();
        if (stripped.Length == 0) return false;
        return stripped[^1] is '}' or ';';
    }
}
