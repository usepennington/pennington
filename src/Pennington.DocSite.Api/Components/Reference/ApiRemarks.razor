@inherits ApiReferenceComponentBase

@((MarkupString)_html)

@code {
    [Parameter, EditorRequired] public string XmlDocId { get; set; } = string.Empty;

    private string _html = string.Empty;

    protected override void OnParametersSet()
    {
        _html = BuildHtml();
    }

    private string BuildHtml()
    {
        if (string.IsNullOrWhiteSpace(XmlDocId))
        {
            return DiagError(MissingAttributeError("ApiRemarks", "XmlDocId"));
        }

        var result = Fetch("ApiRemarks", XmlDocId, p => p.GetXmldocAsync(XmlDocId));
        if (!result.Ok)
        {
            return DiagError(result.ErrorHtml!);
        }

        return result.Value.HasRemarks ? Renderer.RenderHtml(result.Value.Remarks) : string.Empty;
    }
}
