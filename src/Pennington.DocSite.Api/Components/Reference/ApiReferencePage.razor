@* Internal route. Public-facing URLs come in through configured
   {RoutePrefix}/{slug}/ shapes and are rewritten onto this path by
   ApiReferenceRewriteMiddleware, which runs before Blazor routing. Users
   never type or see the /_pnn_api/ prefix. *@
@page "/_pnn_api/{Name}/{Key}"
@layout Pennington.DocSite.Components.Layout.MainLayout
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.Extensions.DependencyInjection
@inject IServiceProvider Services

@if (_entry is null)
{
    <p>Unknown API reference key: <code>@Key</code></p>
}
else
{
    <PageTitle>@_entry.FullTypeName</PageTitle>
    <HeadContent>
        @if (!string.IsNullOrEmpty(_entry.Summary))
        {
            <meta name="description" content="@_entry.Summary" />
        }
    </HeadContent>

    <header class="mb-8">
        <h1 class="font-display font-bold tracking-tight flex flex-wrap items-baseline gap-x-3">
            <span class="text-2xl text-base-900 dark:text-base-50">@_entry.TypeName</span>
            <span class="text-sm font-normal text-caps text-accent-500 dark:text-accent-500">@_entry.Namespace</span>
        </h1>
    </header>

    <CascadingValue Name="ApiSource" Value="@Name">
        <section class="prose dark:prose-invert max-w-none">
            <ApiSummary XmlDocId="@_entry.Uid" />
        </section>

        <section class="mt-8">
            <ApiMemberTable XmlDocId="@_entry.Uid" Kind="All" />
        </section>
    </CascadingValue>
}

@code {
    [Parameter] public required string Name { get; set; }
    [Parameter] public required string Key { get; set; }

    private ApiReferenceEntry? _entry;

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrWhiteSpace(Key)) return;

        var index = Services.GetRequiredKeyedService<ApiReferenceIndex>(Name);
        var entries = await index.GetEntriesAsync();
        if (entries.TryGetValue(Key, out var found))
        {
            _entry = found;
        }
    }
}
