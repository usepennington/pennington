@inherits ApiReferenceComponentBase

@if (_error is not null)
{
    <div class="diag-error">@((MarkupString)_error)</div>
}
else if (_empty is not null)
{
    <p><em>@_empty</em></p>
}
else
{
    <ApiDefinitionList Rows="_rows" />
}

@code {
    [Parameter, EditorRequired] public string XmlDocId { get; set; } = string.Empty;

    private IReadOnlyList<ApiDefinitionRow> _rows = [];
    private string? _error;
    private string? _empty;

    protected override void OnParametersSet()
    {
        _error = null;
        _empty = null;
        _rows = [];

        if (string.IsNullOrWhiteSpace(XmlDocId))
        {
            _error = MissingAttributeError("ApiParameterTable", "XmlDocId");
            return;
        }

        var result = Fetch("ApiParameterTable", XmlDocId, p => p.GetMemberAsync(XmlDocId));
        if (!result.Ok)
        {
            _error = result.ErrorHtml;
            return;
        }

        var member = result.Value;
        if (member is null || member.Kind is not (MemberKind.Methods or MemberKind.Constructors))
        {
            Diagnostics?.AddError($"<ApiParameterTable> expected a method xmldocid (M:...), got {XmlDocId}");
            _error = $"Expected a method xmldocid (M:...), got <code>{WebUtility.HtmlEncode(XmlDocId)}</code>";
            return;
        }

        if (member.Parameters.Length == 0)
        {
            _empty = "This method takes no parameters.";
            return;
        }

        var rows = new List<ApiDefinitionRow>(member.Parameters.Length);
        foreach (var p in member.Parameters)
        {
            rows.Add(new ApiDefinitionRow(
                Name: p.Name,
                TypeDisplay: p.TypeDisplay,
                DefaultValue: null,
                Required: false,
                DescriptionHtml: Renderer.RenderInlineHtml(p.Description)));
        }

        _rows = rows;
    }
}
