@inject ISymbolExtractionService SymbolService
@inject IXmlDocParser Parser
@inject IXmlDocHtmlRenderer Renderer
@inject IHttpContextAccessor HttpContextAccessor

@if (_error is not null)
{
    <div class="diag-error">@((MarkupString)_error)</div>
}
else if (_empty is not null)
{
    <p><em>@_empty</em></p>
}
else
{
    <ApiDefinitionList Rows="_rows" />
}

@code {
    [Parameter, EditorRequired] public string XmlDocId { get; set; } = string.Empty;

    private IReadOnlyList<ApiDefinitionRow> _rows = [];
    private string? _error;
    private string? _empty;

    private DiagnosticContext? Diagnostics =>
        HttpContextAccessor.HttpContext?.RequestServices.GetService<DiagnosticContext>();

    protected override void OnParametersSet()
    {
        _error = null;
        _empty = null;
        _rows = [];

        if (string.IsNullOrWhiteSpace(XmlDocId))
        {
            Diagnostics?.AddError("<ApiParameterTable> missing XmlDocId");
            _error = "&lt;ApiParameterTable&gt; missing XmlDocId";
            return;
        }

        SymbolInfo? info;
        try
        {
            info = AsyncHelpers.RunSync(() => SymbolService.FindSymbolAsync(XmlDocId));
        }
        catch (Exception ex)
        {
            Diagnostics?.AddError($"<ApiParameterTable> resolution failed for {XmlDocId}: {ex.Message}");
            _error = $"Resolution failed: {WebUtility.HtmlEncode(ex.Message)}";
            return;
        }

        if (info?.Symbol is not Microsoft.CodeAnalysis.IMethodSymbol method)
        {
            Diagnostics?.AddError($"<ApiParameterTable> expected a method xmldocid (M:...), got {XmlDocId}");
            _error = $"Expected a method xmldocid (M:...), got <code>{WebUtility.HtmlEncode(XmlDocId)}</code>";
            return;
        }

        if (method.Parameters.Length == 0)
        {
            _empty = "This method takes no parameters.";
            return;
        }

        var parsed = Parser.Parse(method.GetDocumentationCommentXml());

        var rows = new List<ApiDefinitionRow>(method.Parameters.Length);
        var displayFormat = new Microsoft.CodeAnalysis.SymbolDisplayFormat(
            genericsOptions: Microsoft.CodeAnalysis.SymbolDisplayGenericsOptions.IncludeTypeParameters,
            miscellaneousOptions: Microsoft.CodeAnalysis.SymbolDisplayMiscellaneousOptions.UseSpecialTypes
                | Microsoft.CodeAnalysis.SymbolDisplayMiscellaneousOptions.IncludeNullableReferenceTypeModifier,
            typeQualificationStyle: Microsoft.CodeAnalysis.SymbolDisplayTypeQualificationStyle.NameAndContainingTypes);

        foreach (var p in method.Parameters)
        {
            var typeDisplay = p.Type.ToDisplayString(displayFormat);
            var description = parsed.Params.TryGetValue(p.Name, out var nodes)
                ? Renderer.RenderInlineHtml(nodes)
                : string.Empty;

            rows.Add(new ApiDefinitionRow(
                Name: p.Name,
                TypeDisplay: typeDisplay,
                DefaultValue: null,
                Required: false,
                DescriptionHtml: description));
        }

        _rows = rows;
    }
}
