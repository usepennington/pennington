@inherits ApiReferenceComponentBase

@((MarkupString)_html)

@code {
    [Parameter, EditorRequired] public string XmlDocId { get; set; } = string.Empty;

    private string _html = string.Empty;

    protected override void OnParametersSet()
    {
        _html = BuildHtml();
    }

    private string BuildHtml()
    {
        if (string.IsNullOrWhiteSpace(XmlDocId))
        {
            return DiagError(MissingAttributeError("ApiSeeAlso", "XmlDocId"));
        }

        var result = Fetch("ApiSeeAlso", XmlDocId, p => p.GetXmldocAsync(XmlDocId));
        if (!result.Ok)
        {
            return DiagError(result.ErrorHtml!);
        }

        var parsed = result.Value;
        if (parsed.SeeAlso.Length == 0)
        {
            return string.Empty;
        }

        var sb = new StringBuilder("<ul>");
        foreach (var cref in parsed.SeeAlso)
        {
            sb.Append("<li><code>").Append(WebUtility.HtmlEncode(UidDisplay.Shorten(cref))).Append("</code></li>");
        }

        sb.Append("</ul>");
        return sb.ToString();
    }
}
