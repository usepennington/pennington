@inject ISymbolExtractionService SymbolService
@inject IXmlDocParser Parser
@inject IHttpContextAccessor HttpContextAccessor

@((MarkupString)_html)

@code {
    [Parameter, EditorRequired] public string XmlDocId { get; set; } = string.Empty;

    private string _html = string.Empty;

    private DiagnosticContext? Diagnostics =>
        HttpContextAccessor.HttpContext?.RequestServices.GetService<DiagnosticContext>();

    protected override void OnParametersSet()
    {
        _html = BuildHtml();
    }

    private string BuildHtml()
    {
        if (string.IsNullOrWhiteSpace(XmlDocId))
        {
            Diagnostics?.AddError("<ApiSeeAlso> missing XmlDocId");
            return "<div class=\"diag-error\">&lt;ApiSeeAlso&gt; missing XmlDocId</div>";
        }

        var info = AsyncHelpers.RunSync(() => SymbolService.FindSymbolAsync(XmlDocId));
        if (info is null)
        {
            Diagnostics?.AddError($"<ApiSeeAlso> unresolved xmldocid: {XmlDocId}");
            return $"<div class=\"diag-error\">Unresolved xmldocid: <code>{WebUtility.HtmlEncode(XmlDocId)}</code></div>";
        }

        var parsed = Parser.Parse(info.Symbol.GetDocumentationCommentXml());
        if (parsed.SeeAlso.Length == 0)
        {
            return string.Empty;
        }

        var sb = new StringBuilder("<ul>");
        foreach (var cref in parsed.SeeAlso)
        {
            sb.Append("<li><code>").Append(WebUtility.HtmlEncode(Shorten(cref))).Append("</code></li>");
        }

        sb.Append("</ul>");
        return sb.ToString();
    }

    private static string Shorten(string crefId)
    {
        var cleaned = crefId.Length >= 2 && crefId[1] == ':' ? crefId[2..] : crefId;
        var parenIndex = cleaned.IndexOf('(');
        if (parenIndex >= 0)
        {
            cleaned = cleaned[..parenIndex];
        }

        var lastDot = cleaned.LastIndexOf('.');
        return lastDot >= 0 ? cleaned[(lastDot + 1)..] : cleaned;
    }
}
