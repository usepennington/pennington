@inherits ApiReferenceComponentBase

@if (_error is not null)
{
    <div class="diag-error">@((MarkupString)_error)</div>
}
else if (!string.IsNullOrEmpty(_html))
{
    @((MarkupString)_html)
}

@code {
    [Parameter, EditorRequired] public string XmlDocId { get; set; } = string.Empty;

    private string _html = string.Empty;
    private string? _error;

    protected override void OnParametersSet()
    {
        _error = null;
        _html = string.Empty;

        if (string.IsNullOrWhiteSpace(XmlDocId))
        {
            _error = MissingAttributeError("ApiSummary", "XmlDocId");
            return;
        }

        var result = Fetch("ApiSummary", XmlDocId, p => p.GetXmldocAsync(XmlDocId));
        if (!result.Ok)
        {
            _error = result.ErrorHtml;
            return;
        }

        var parsed = result.Value;
        if (!parsed.HasSummary)
        {
            Diagnostics?.AddWarning($"<ApiSummary> {XmlDocId} has no <summary>");
            return;
        }

        _html = Renderer.RenderHtml(parsed.Summary);
    }
}
