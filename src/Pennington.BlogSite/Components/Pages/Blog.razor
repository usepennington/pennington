@page "/blog/{*fileName:nonfile}"
@using Pennington.Routing
@using Pennington.SocialCards
@inject PenningtonOptions PenningtonOptions
@inject BlogSiteOptions BlogOptions
@inject BlogContentResolver ContentResolver
@inject IHttpContextAccessor HttpContextAccessor

@if (_rendered == null)
{
    <div>Post not found</div>
    return;
}
<PageTitle>@PenningtonOptions.SiteTitle - @_rendered.Page.FrontMatter.Title</PageTitle>

<HeadContent>
    @{ var socialImage = GetSocialImageUrl(); }
    <meta property="og:title" content="@_rendered.Page.FrontMatter.Title" />
    <meta property="og:description" content="@_rendered.Page.FrontMatter.Description" />
    @if (!string.IsNullOrEmpty(socialImage))
    {
        <meta property="og:image" content="@socialImage" />
    }
    <meta property="og:url" content="@GetFullUrl()" />
    <meta property="og:type" content="article" />
    <meta property="og:site_name" content="@PenningtonOptions.SiteTitle" />
    @if (_rendered.Page.FrontMatter.Date.HasValue)
    {
        <meta property="article:published_time" content="@_rendered.Page.FrontMatter.Date.Value.ToString("yyyy-MM-ddTHH:mm:ssZ")" />
    }

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@_rendered.Page.FrontMatter.Title" />
    <meta name="twitter:description" content="@_rendered.Page.FrontMatter.Description" />
    @if (!string.IsNullOrEmpty(socialImage))
    {
        <meta name="twitter:image" content="@socialImage" />
    }
</HeadContent>

<BlogPost Post="_rendered.Page" HtmlContent="@_rendered.Html" Series="_series"/>

@code{
    [Parameter] public required string FileName { get; init; }
    private RenderedBlogPost? _rendered;
    private List<BlogPostPage>? _series;

    protected override async Task OnInitializedAsync()
    {
        var url = $"{BlogOptions.BlogBaseUrl}/{FileName}";
        _rendered = await ContentResolver.GetPostByUrlAsync(url);

        if (_rendered == null && HttpContextAccessor.HttpContext is { } ctx)
        {
            // Signal to NotFoundStatusProcessor — setting StatusCode here
            // directly would gate every IResponseProcessor (ShouldProcess
            // skips on non-2xx) and ship an empty body to the client.
            ctx.Items["Pennington.NotFound"] = true;
        }

        if (_rendered != null && !string.IsNullOrWhiteSpace(_rendered.Page.FrontMatter.Series))
        {
            var allPosts = await ContentResolver.GetAllPostsAsync();
            _series = allPosts
                .Where(i => string.Equals(i.FrontMatter.Series, _rendered.Page.FrontMatter.Series, StringComparison.OrdinalIgnoreCase))
                .OrderBy(i => i.FrontMatter.Date)
                .ToList();
        }
    }

    private string GetSocialImageUrl()
    {
        if (_rendered == null) return "";

        // An explicit author-supplied image wins, preserving the existing factory behavior.
        if (BlogOptions.SocialMediaImageUrlFactory?.Invoke(_rendered.Page) is { Length: > 0 } imageUrl)
        {
            return imageUrl.StartsWith('/') ? $"{PenningtonOptions.CanonicalBaseUrl}{imageUrl}" : imageUrl;
        }

        // Otherwise fall back to a generated social card when enabled.
        if (BlogOptions.SocialCards is { } cards)
        {
            return SocialCardUrl.For(new UrlPath(_rendered.Page.Url), cards.BaseUrl, PenningtonOptions.CanonicalBaseUrl);
        }

        return "";
    }

    private string GetFullUrl() => _rendered == null ? "" : $"{PenningtonOptions.CanonicalBaseUrl}{_rendered.Page.Url}";
}
