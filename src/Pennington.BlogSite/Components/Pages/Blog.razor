@page "/blog/{*fileName:nonfile}"
@using Pennington.Routing
@using Pennington.SocialCards
@using Pennington.LlmsTxt
@using Microsoft.Extensions.DependencyInjection
@inject PenningtonOptions PenningtonOptions
@inject BlogSiteOptions BlogOptions
@inject BlogPostQuery Posts
@inject IHttpContextAccessor HttpContextAccessor
@inject IServiceProvider Services

@if (_rendered == null)
{
    <div>Post not found</div>
    return;
}
@{
    var fm = _rendered.FrontMatter;
    var post = new BlogPostRef<BlogSiteFrontMatter>(fm, _rendered.Url);
}
<PageTitle>@PenningtonOptions.SiteTitle - @fm.Title</PageTitle>

<HeadContent>
    @{ var socialImage = GetSocialImageUrl(post); }
    @if (MarkdownAlternateHref() is { } mdHref)
    {
        <link rel="alternate" type="text/markdown" href="@mdHref" />
    }
    <meta property="og:title" content="@fm.Title" />
    <meta property="og:description" content="@fm.Description" />
    @if (!string.IsNullOrEmpty(socialImage))
    {
        <meta property="og:image" content="@socialImage" />
    }
    <meta property="og:url" content="@GetFullUrl()" />
    <meta property="og:type" content="article" />
    <meta property="og:site_name" content="@PenningtonOptions.SiteTitle" />
    @if (fm.Date.HasValue)
    {
        <meta property="article:published_time" content="@fm.Date.Value.ToString("yyyy-MM-ddTHH:mm:ssZ")" />
    }

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@fm.Title" />
    <meta name="twitter:description" content="@fm.Description" />
    @if (!string.IsNullOrEmpty(socialImage))
    {
        <meta name="twitter:image" content="@socialImage" />
    }
</HeadContent>

<BlogPost Post="post" HtmlContent="@_rendered.Html" Series="_series"/>

@code{
    [Parameter] public required string FileName { get; init; }
    private RenderedBlogPost<BlogSiteFrontMatter>? _rendered;
    private List<BlogPostRef<BlogSiteFrontMatter>>? _series;

    protected override async Task OnInitializedAsync()
    {
        var url = $"{BlogOptions.BlogBaseUrl}/{FileName}";
        _rendered = await Posts.GetRenderedPostAsync<BlogSiteFrontMatter>(new UrlPath(url));

        if (_rendered == null)
        {
            // Signal to NotFoundStatusProcessor — setting StatusCode here directly would gate every
            // IResponseProcessor (ShouldProcess skips on non-2xx) and ship an empty body to the client.
            HttpContextAccessor.HttpContext?.MarkNotFound();
            return;
        }

        if (!string.IsNullOrWhiteSpace(_rendered.FrontMatter.Series))
        {
            var allPosts = await Posts.GetPostsAsync<BlogSiteFrontMatter>(BlogOptions.BlogBaseUrl);
            _series = allPosts
                .Where(i => string.Equals(i.FrontMatter.Series, _rendered.FrontMatter.Series, StringComparison.OrdinalIgnoreCase))
                .OrderBy(i => i.FrontMatter.Date)
                .ToList();
        }
    }

    private string GetSocialImageUrl(BlogPostRef<BlogSiteFrontMatter> post)
    {
        // An explicit author-supplied image wins, preserving the existing factory behavior.
        if (BlogOptions.SocialMediaImageUrlFactory?.Invoke(post) is { Length: > 0 } imageUrl)
        {
            return imageUrl.StartsWith('/') ? $"{PenningtonOptions.CanonicalBaseUrl}{imageUrl}" : imageUrl;
        }

        // Otherwise fall back to a generated social card when enabled.
        if (BlogOptions.SocialCards is { } cards)
        {
            return SocialCardUrl.For(post.Url, cards.BaseUrl, PenningtonOptions.CanonicalBaseUrl);
        }

        return "";
    }

    private string GetFullUrl() => _rendered == null ? "" : $"{PenningtonOptions.CanonicalBaseUrl}{_rendered.Url.Value}";

    // Advertises the post's co-located markdown copy (post URL + index.md) as an alternate
    // representation for content-negotiating agents (Claude Code's WebFetch sends
    // Accept: text/markdown). Pure string math on the post's own canonical URL — no llms-service
    // lookup — gated on llms generation being enabled and the post not opting out via `llms: false`.
    private string? MarkdownAlternateHref()
    {
        if (_rendered is null || !_rendered.FrontMatter.Llms || Services.GetService<LlmsTxtOptions>() is null)
        {
            return null;
        }

        var key = _rendered.Url.Value.Trim('/');
        return key.Length == 0 ? "/index.md" : $"/{key}/index.md";
    }
}
