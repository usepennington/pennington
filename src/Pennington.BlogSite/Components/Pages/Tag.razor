@layout ContentWithProseLayout
@page "/tags/{TagEncodedName}"
@inject TaxonomyAccessor Taxonomy
@inject PenningtonOptions PenningtonOptions

@if (_term == null)
{
    <div>Unknown tag</div>
    return;
}

<PageTitle>@PenningtonOptions.SiteTitle - @_term.Label</PageTitle>

<header>
    <h1>@_term.Label</h1>
    <p>Blog posts tagged by <span class="text-primary-800 dark:text-primary-300">@_term.Label</span></p>
</header>
<div class="not-prose">
    <BlogPostsList Posts="_posts" />
</div>

@code {
    /// <summary>Tag slug from the route, matched against the taxonomy term slug.</summary>
    [Parameter] public required string TagEncodedName { get; set; }

    private TaxonomyTerm<BlogSiteFrontMatter, string>? _term;
    private IReadOnlyList<BlogPostRef<BlogSiteFrontMatter>> _posts = [];

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrWhiteSpace(TagEncodedName))
        {
            return;
        }

        _term = await Taxonomy.TryGetTermAsync<BlogSiteFrontMatter, string>("/tags", TagEncodedName);
        if (_term != null)
        {
            _posts = _term.Items
                .Select(i => new BlogPostRef<BlogSiteFrontMatter>(i.FrontMatter, i.Url))
                .ToList();
        }
    }
}
