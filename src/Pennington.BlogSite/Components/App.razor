@using Microsoft.AspNetCore.WebUtilities
@using Microsoft.Extensions.DependencyInjection
@using Pennington.LlmsTxt
@inject PenningtonOptions Options
@inject BlogSiteOptions BlogOptions
@inject IWebHostEnvironment WebHostEnvironment
@inject IServiceProvider Services
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>

    @if (BlogOptions.EnableRss)
    {
        <link type="application/rss+xml" rel="alternate" title="@Options.SiteTitle" href="/rss.xml" />
    }
    @if (Services.GetService<LlmsTxtOptions>() is not null)
    {
        <link rel="alternate" type="text/markdown" title="LLM-friendly site index" href="/llms.txt" />
    }
    @foreach (var font in BlogOptions.FontPreloads)
    {
        @* Skip when the referenced file isn't shipped — emitting a preload hint
           for a non-existent file causes a 404 on every page load. *@
        @if (FontPreloadExists(font.Href))
        {
            <link rel="preload" href="@font.Href" as="font" type="@font.Type" crossorigin>
        }
    }
    <link rel="stylesheet" href="@GetVersioned("/styles.css")">
    <script src="@GetVersioned("/_content/DeweySearch.Web/dewey-search.js")" defer></script>
    <script src="@GetVersioned("/_content/Pennington.UI/scripts.js")" defer></script>

    @if (!string.IsNullOrEmpty(BlogOptions.AdditionalHtmlHeadContent))
    {
        @((MarkupString)BlogOptions.AdditionalHtmlHeadContent)
    }

    <meta name="description" content="@Options.SiteDescription">

    <script>
        if (localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
        } else {
            document.documentElement.classList.remove('dark');
        }
    </script>
    @* Default title — pages override via their own <PageTitle> from a child
       component. Must register BEFORE <HeadOutlet/>, otherwise the
       SectionContent registered here lands after the outlet has already
       rendered and never makes it into the response. The same ordering
       constraint is why pages' <HeadContent> emits the og/twitter meta tags
       only when HeadOutlet sits last in <head>. *@
    <PageTitle>@Options.SiteTitle</PageTitle>
    <HeadOutlet/>
</head>

<body data-mobile-menu-open="false" class="data-[mobile-menu-open=true]:overflow-hidden">
    <Routes/>
</body>
</html>

@code{
    static readonly string Version = DateTime.Now.Ticks.ToString();

    string GetVersioned(string url) => WebHostEnvironment.IsDevelopment()
            ? url
            : QueryHelpers.AddQueryString(url, "v", Version);

    bool FontPreloadExists(string href)
    {
        if (string.IsNullOrEmpty(href)) return false;
        var path = href.StartsWith('/') ? href[1..] : href;
        if (WebHostEnvironment.WebRootFileProvider.GetFileInfo(path).Exists) return true;
        // Pennington also serves Content/ as static files — check there before
        // declaring the preload broken.
        var contentRoot = System.IO.Path.IsPathRooted(Options.ContentRootPath.Value)
            ? Options.ContentRootPath.Value
            : System.IO.Path.Combine(WebHostEnvironment.ContentRootPath, Options.ContentRootPath.Value);
        return System.IO.File.Exists(System.IO.Path.Combine(contentRoot, path));
    }
}
