@if (AlternateLanguages.Count > 1)
{
    <details class="relative">
        <summary class="flex items-center gap-1 rounded-md px-2 py-1 text-sm text-base-600 dark:text-base-300 hover:bg-base-200 dark:hover:bg-base-800 cursor-pointer list-none [&::-webkit-details-marker]:hidden"
                 aria-label="Switch language">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12.87 15.07l-2.54-2.51.03-.03A17.52 17.52 0 0014.07 6H17V4h-7V2H8v2H1v2h11.17C11.5 7.92 10.44 9.75 9 11.35 8.07 10.32 7.3 9.19 6.69 8h-2c.73 1.63 1.73 3.17 2.98 4.56l-5.09 5.02L4 19l5-5 3.11 3.11.76-2.04zM18.5 10h-2L12 22h2l1.12-3h4.75L21 22h2l-4.5-12zm-2.62 7l1.62-4.33L19.12 17h-3.24z" fill="currentColor" stroke="none"/>
            </svg>
            <span>@CurrentDisplayName</span>
        </summary>
        <div class="absolute right-0 z-20 mt-1 min-w-32 rounded-md border border-base-200 dark:border-base-700 bg-base-50 dark:bg-base-900 py-1 shadow-lg">
            @foreach (var lang in AlternateLanguages)
            {
                <a href="@lang.Url"
                   data-spa-reload
                   class="block px-3 py-1.5 text-sm @(lang.IsCurrentLocale ? "font-semibold text-primary-600 dark:text-primary-400" : "text-base-700 dark:text-base-300") hover:bg-base-100 dark:hover:bg-base-800">
                    @lang.DisplayName
                </a>
            }
        </div>
    </details>
}

@code {
    [Parameter] public IReadOnlyList<AlternateLanguageItem> AlternateLanguages { get; set; } = [];

    private string CurrentDisplayName => AlternateLanguages
        .FirstOrDefault(l => l.IsCurrentLocale)?.DisplayName ?? "";

    public record AlternateLanguageItem(string Locale, string DisplayName, string Url, bool IsCurrentLocale);
}
