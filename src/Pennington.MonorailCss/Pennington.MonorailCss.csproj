<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net10.0;net11.0</TargetFrameworks>
    <LangVersion>preview</LangVersion>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <Description>MonorailCSS integration for Pennington providing utility-first CSS generation</Description>
    <PackageTags>dotnet css utility-css monorail tailwind</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Pennington\Pennington.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="MonorailCss" />
    <PackageReference Include="MonorailCss.Discovery" />
  </ItemGroup>
</Project>
