<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net11.0</TargetFramework>
    <LangVersion>preview</LangVersion>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <Description>MonorailCSS integration for Pennington providing utility-first CSS generation</Description>
    <PackageTags>dotnet css utility-css monorail tailwind</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Pennington\Pennington.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="MonorailCss" Version="0.0.5-alpha.0.72" />
  </ItemGroup>
</Project>
