<Project Sdk="Microsoft.NET.Sdk.Razor">
  <PropertyGroup>
    <TargetFrameworks>net11.0;net10.0</TargetFrameworks>
    <LangVersion>preview</LangVersion>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AddRazorSupportForMvc>true</AddRazorSupportForMvc>
    <Description>Documentation site template for Pennington with layouts, pages, and content resolution</Description>
    <PackageTags>dotnet documentation-site static-site template</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Pennington\Pennington.csproj" />
    <ProjectReference Include="..\Pennington.UI\Pennington.UI.csproj" />
    <ProjectReference Include="..\Pennington.MonorailCss\Pennington.MonorailCss.csproj" />
  </ItemGroup>
</Project>
