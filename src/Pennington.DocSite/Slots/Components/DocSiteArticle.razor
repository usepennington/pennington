@using Pennington.UI.Components

@if (!string.IsNullOrEmpty(FallbackRequestedLocale))
{
    <FallbackNotice RequestedLocale="@FallbackRequestedLocale" DefaultLocale="@FallbackDefaultLocale" />
}

<header class="pb-8 mb-10 border-b border-base-200 dark:border-base-800">
    @if (!string.IsNullOrEmpty(AreaTitle))
    {
        <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 mb-4 rounded-full font-display text-[11px] font-semibold uppercase tracking-[0.06em] bg-primary-500/10 text-primary-800 dark:text-primary-200 border border-primary-500/20">
            @if (!string.IsNullOrEmpty(AreaIconHtml))
            {
                <span class="w-3 h-3 shrink-0">@((MarkupString)AreaIconHtml)</span>
            }
            @AreaTitle
        </span>
    }
    <h1 class="font-display font-extrabold text-[2rem] lg:text-[2.25rem] leading-[1.1] tracking-[-0.022em] text-base-900 dark:text-base-50">@Title</h1>
    @if (!string.IsNullOrEmpty(Description))
    {
        <p class="mt-3 text-[1.0625rem] leading-[1.65] text-base-500 dark:text-base-400 wrap-pretty">@Description</p>
    }
</header>

<main class="prose dark:prose-invert dark:text-base-300 max-w-full prose-sm min-w-0 prose-headings:scroll-m-20 prose-headings:font-display prose-headings:text-base-900 dark:prose-headings:text-base-50">
    @((MarkupString)HtmlContent)
</main>

@if (PreviousPageName is not null || NextPageName is not null)
{
    <nav class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-16" aria-label="Page navigation">
        @if (PreviousPageName is not null)
        {
            <a href="@PreviousPageHref" class="@PagerCardClass flex flex-col gap-1">
                <span class="@PagerEyebrowClass">
                    <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
                    Previous
                </span>
                <span class="@PagerTitleClass">@PreviousPageName</span>
            </a>
        }
        else
        {
            <span></span>
        }
        @if (NextPageName is not null)
        {
            <a href="@NextPageHref" class="@PagerCardClass flex flex-col gap-1 text-right items-end">
                <span class="@PagerEyebrowClass">
                    Next
                    <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </span>
                <span class="@PagerTitleClass">@NextPageName</span>
            </a>
        }
    </nav>
}

@code {
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public string HtmlContent { get; set; } = "";
    [Parameter] public string? Description { get; set; }
    [Parameter] public string? AreaTitle { get; set; }
    [Parameter] public string? AreaIconHtml { get; set; }
    [Parameter] public string? PreviousPageName { get; set; }
    [Parameter] public string? PreviousPageHref { get; set; }
    [Parameter] public string? NextPageName { get; set; }
    [Parameter] public string? NextPageHref { get; set; }
    [Parameter] public string? FallbackRequestedLocale { get; set; }
    [Parameter] public string? FallbackDefaultLocale { get; set; }

    private const string PagerCardClass =
        "p-4 rounded-xl border border-base-200 dark:border-base-800 bg-base-50 dark:bg-base-900 " +
        "hover:border-primary-500/50 dark:hover:border-primary-300/40 transition-colors";

    private const string PagerEyebrowClass =
        "inline-flex items-center gap-1.5 font-display text-[12.5px] font-medium text-base-500 dark:text-base-400";

    private const string PagerTitleClass =
        "font-display font-semibold text-[0.95rem] text-base-900 dark:text-base-50";
}
