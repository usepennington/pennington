@page "/blog/tags/{tagSlug}"
@layout BlogLayout
@using Pennington.Content
@using Pennington.Infrastructure
@using Pennington.Taxonomy
@inject TaxonomyAccessor Taxonomy
@inject BlogFeature Feature
@inject DocSiteOptions DocSiteOptions
@inject IHttpContextAccessor HttpContextAccessor

@if (_term != null)
{
    <PageTitle>@_term.Label — @DocSiteOptions.SiteTitle</PageTitle>

    <header class="mb-8">
        <p class="text-sm uppercase tracking-wide text-base-500 dark:text-base-400">Tag</p>
        <h1 class="font-display text-3xl font-bold tracking-tight text-base-900 dark:text-base-50">@_term.Label</h1>
    </header>

    <ul class="divide-y divide-base-200 dark:divide-base-800">
        @foreach (var item in _term.Items)
        {
            <BlogPostCard Post="@(new BlogPostRef<BlogPostFrontMatter>(item.FrontMatter, item.Url))" />
        }
    </ul>

    <nav class="mt-12 border-t border-base-200 dark:border-base-800 pt-6">
        <a href="/blog/tags" class="text-sm font-medium text-primary-700 dark:text-primary-400 hover:underline">All tags</a>
    </nav>
}

@code {
    /// <summary>Tag slug from the route, matched against the taxonomy term slug.</summary>
    [Parameter] public required string TagSlug { get; set; }

    private TaxonomyTerm<BlogPostFrontMatter, string>? _term;

    protected override async Task OnInitializedAsync()
    {
        if (Feature.Enabled && !string.IsNullOrWhiteSpace(TagSlug))
        {
            _term = await Taxonomy.TryGetTermAsync<BlogPostFrontMatter, string>("/blog/tags", TagSlug);
            if (_term != null)
            {
                return;
            }
        }

        HttpContextAccessor.HttpContext?.MarkNotFound();
    }
}
