@using Microsoft.AspNetCore.WebUtilities
@using Microsoft.AspNetCore.Hosting
@using Microsoft.Extensions.Hosting
@using Microsoft.Extensions.DependencyInjection
@using Pennington.Infrastructure
@using Pennington.LlmsTxt
@inject IWebHostEnvironment WebHostEnvironment
@inject DocSiteOptions DocSiteOptions
@inject PenningtonOptions PenningtonOptions
@inject LocalizationOptions Localization
@inject Localization.LocaleContext Locale
@inject IServiceProvider Services

<!DOCTYPE html>
<html lang="@Locale.HtmlLang" dir="@Locale.Direction" class="bg-base-100 dark:bg-base-950 dark:scheme-dark">

<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>

    @foreach (var font in DocSiteOptions.FontPreloads)
    {
        @* Skip when the referenced file isn't shipped — emitting a preload hint
           for a non-existent file causes a 404 on every page load. *@
        @if (FontPreloadExists(font.Href))
        {
            <link rel="preload" href="@font.Href" as="font" type="@font.Type" crossorigin>
        }
    }
    <link rel="stylesheet" href="@GetVersioned("/styles.css")">
    @* scripts.js pulls in DeweySearch.Web's client on demand the first time the
       search modal opens — no separate dewey-search.js tag needed here. *@
    <script src="@GetVersioned("/_content/Pennington.UI/scripts.js")" defer></script>
    <script src="@GetVersioned("/_content/Pennington.UI/spa-engine.js")" defer></script>

    @if (!string.IsNullOrEmpty(DocSiteOptions.AdditionalHtmlHeadContent))
    {
        @((MarkupString)DocSiteOptions.AdditionalHtmlHeadContent)
    }

    <script>
        (function () {
            try {
                const stored = localStorage.getItem('theme');
                const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
                const dark = stored ? stored === 'dark' : prefersDark;
                if (dark) document.documentElement.classList.add('dark');
            } catch (e) { }
            // Keep <meta name="theme-color"> (mobile browser chrome) matched to
            // the painted root background, whatever the configured palette
            // resolves it to. Reused by the theme toggle in scripts.js.
            window.syncThemeColor = function () {
                try {
                    const bg = getComputedStyle(document.documentElement).backgroundColor;
                    let meta = document.querySelector('meta[name="theme-color"]');
                    if (!meta) { meta = document.createElement('meta'); meta.name = 'theme-color'; document.head.appendChild(meta); }
                    meta.content = bg;
                } catch (e) { }
            };
            window.syncThemeColor();
        })();
    </script>

    <HeadOutlet/>
</head>

<body data-mobile-menu-open="false"
      class="data-[mobile-menu-open=true]:overflow-hidden"
      data-locales="@(Localization.IsMultiLocale ? string.Join(",", Localization.Locales.Keys) : "")"
      data-default-locale="@Localization.DefaultLocale">
@* The per-page <link rel="alternate" type="text/markdown"> lives in the page <head>
   (Pages.razor) — but WebFetch-style HTML extractors strip <head> metadata while
   preserving display:none body content, so this .robots-only paragraph carries the
   hint through to extracting agents the head link can't reach.
   Wording matters: a blind-agent A/B run found that the old passive
   "an index exists" phrasing was reliably NOTICED but ignored — agents that
   already had a usable HTML answer saw no reason to switch. Naming the
   per-page Markdown convention plus the token-cost of parsing this HTML is
   what actually moved weaker/non-Claude agents (which do not guess the
   /llms.txt convention) from ~0% to using the Markdown. Phrasing stays
   declarative — a fact about the site, not an instruction to the reader — so
   it slips past prompt-injection heuristics. (This body hint states the
   convention generically rather than this page's exact URL: App.razor renders
   for every route, including ones with no sidecar such as the generated API
   reference, whereas the head link is emitted only on pages that have one.) *@
@if (Services.GetService<LlmsTxtOptions>() is not null)
{
    <p class="robots-only">This documentation is also published as Markdown for efficient machine reading: the whole site is indexed at <a href="/llms.txt">/llms.txt</a>, and every page has a clean Markdown copy at the same URL with <code>.md</code> appended. These are generated from the same source and cost far fewer tokens to read than this rendered HTML.</p>
}
<div>
    <Routes/>
</div>
</body>
</html>

@code{
    static readonly string Version = DateTime.Now.Ticks.ToString();

    string GetVersioned(string url) => WebHostEnvironment.IsDevelopment()
        ? url
        : QueryHelpers.AddQueryString(url, "v", Version);

    bool FontPreloadExists(string href)
    {
        if (string.IsNullOrEmpty(href)) return false;
        var path = href.StartsWith('/') ? href[1..] : href;
        if (WebHostEnvironment.WebRootFileProvider.GetFileInfo(path).Exists) return true;
        // Pennington also serves Content/ as static files — check there before
        // declaring the preload broken.
        var contentRoot = FilePath.ResolveAgainstRoot(PenningtonOptions.ContentRootPath.Value, WebHostEnvironment.ContentRootPath);
        return System.IO.File.Exists(System.IO.Path.Combine(contentRoot, path));
    }
}
