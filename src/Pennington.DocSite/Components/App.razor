@using Microsoft.AspNetCore.WebUtilities
@using Microsoft.AspNetCore.Hosting
@using Microsoft.Extensions.Hosting
@using Microsoft.Extensions.DependencyInjection
@using Pennington.Infrastructure
@using Pennington.LlmsTxt
@inject IWebHostEnvironment WebHostEnvironment
@inject DocSiteOptions DocSiteOptions
@inject PenningtonOptions PenningtonOptions
@inject LocalizationOptions Localization
@inject Localization.LocaleContext Locale
@inject IServiceProvider Services

<!DOCTYPE html>
<html lang="@Locale.HtmlLang" dir="@Locale.Direction">

<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>

    @foreach (var font in DocSiteOptions.FontPreloads)
    {
        @* Skip when the referenced file isn't shipped — emitting a preload hint
           for a non-existent file causes a 404 on every page load. *@
        @if (FontPreloadExists(font.Href))
        {
            <link rel="preload" href="@font.Href" as="font" type="@font.Type" crossorigin>
        }
    }
    <link rel="stylesheet" href="@GetVersioned("/styles.css")">
    <script src="@GetVersioned("/_content/DeweySearch.Web/dewey-search.js")" defer></script>
    <script src="@GetVersioned("/_content/Pennington.UI/scripts.js")" defer></script>
    <script src="@GetVersioned("/_content/Pennington.UI/spa-engine.js")" defer></script>

    @* When llms.txt is enabled the host registers LlmsTxtOptions; advertise the
       site index as an alternate markdown representation so an agent reading the
       page head can discover it without knowing the conventional path. *@
    @if (Services.GetService<LlmsTxtOptions>() is not null)
    {
        <link rel="alternate" type="text/markdown" title="LLM-friendly site index" href="/llms.txt" />
    }

    @if (!string.IsNullOrEmpty(DocSiteOptions.AdditionalHtmlHeadContent))
    {
        @((MarkupString)DocSiteOptions.AdditionalHtmlHeadContent)
    }

    <script>
        (function () {
            try {
                const stored = localStorage.getItem('theme');
                const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
                const dark = stored ? stored === 'dark' : prefersDark;
                if (dark) document.documentElement.classList.add('dark');
            } catch (e) { }
        })();
    </script>

    <HeadOutlet/>
</head>

<body data-mobile-menu-open="false"
      class="data-[mobile-menu-open=true]:overflow-hidden"
      data-locales="@(Localization.IsMultiLocale ? string.Join(",", Localization.Locales.Keys) : "")"
      data-default-locale="@Localization.DefaultLocale">
@* WebFetch-style HTML extractors strip <head> metadata (including the
   <link rel="alternate"> above) but preserve display:none body content, so
   the .robots-only paragraph carries the same hint through to extracting
   agents. Phrasing is declarative — a fact about the site, not an
   instruction to the reader — so it slips past prompt-injection heuristics. *@
@if (Services.GetService<LlmsTxtOptions>() is not null)
{
    <p class="robots-only">This site provides a machine-readable index at <a href="/llms.txt">/llms.txt</a>.</p>
}
<div>
    <Routes/>
</div>
</body>
</html>

@code{
    static readonly string Version = DateTime.Now.Ticks.ToString();

    string GetVersioned(string url) => WebHostEnvironment.IsDevelopment()
        ? url
        : QueryHelpers.AddQueryString(url, "v", Version);

    bool FontPreloadExists(string href)
    {
        if (string.IsNullOrEmpty(href)) return false;
        var path = href.StartsWith('/') ? href[1..] : href;
        if (WebHostEnvironment.WebRootFileProvider.GetFileInfo(path).Exists) return true;
        // Pennington also serves Content/ as static files — check there before
        // declaring the preload broken.
        var contentRoot = System.IO.Path.IsPathRooted(PenningtonOptions.ContentRootPath.Value)
            ? PenningtonOptions.ContentRootPath.Value
            : System.IO.Path.Combine(WebHostEnvironment.ContentRootPath, PenningtonOptions.ContentRootPath.Value);
        return System.IO.File.Exists(System.IO.Path.Combine(contentRoot, path));
    }
}
