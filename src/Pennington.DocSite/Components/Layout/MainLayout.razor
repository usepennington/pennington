@using Pennington.DocSite.Services
@using Pennington.Generation
@using Pennington.Infrastructure
@inherits LayoutComponentBase
@inject ContentResolver ContentResolver
@inject NavigationBuilder NavBuilder
@inject NavigationManager NavigationManager
@inject DocSiteOptions DocSiteOptions
@inject LocalizationOptions Localization
@inject IHttpContextAccessor HttpContextAccessor

<HeadContent>
    @if (!string.IsNullOrEmpty(DocSiteOptions.SocialImageUrl))
    {
        <meta property="og:image" content="@DocSiteOptions.SocialImageUrl" />
        <meta name="twitter:image" content="@DocSiteOptions.SocialImageUrl" />
        <meta name="twitter:card" content="summary_large_image" />
    }
    <meta property="og:site_name" content="@DocSiteOptions.SiteTitle" />
    <meta property="og:type" content="website" />
    <meta name="twitter:site" content="@DocSiteOptions.SiteTitle" />
</HeadContent>

<div class="dark:scheme-dark font-sans box-border bg-base-100 dark:bg-base-950 text-base-900 dark:text-base-50">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-50 focus:bg-primary-700 focus:text-white focus:p-3">Skip to main content</a>
    <a href="#nav-sidebar" class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-50 focus:bg-primary-700 focus:text-white focus:p-3">Skip to navigation</a>
    <div style="scrollbar-gutter: stable both-edges;">
        <!-- Mobile overlay -->
        <div id="mobile-overlay" class="fixed inset-0 bg-base-950/50 backdrop-blur z-30 lg:hidden aria-hidden:hidden"
             aria-hidden="true"></div>

        <div class="flex flex-row min-h-screen w-full">
            @* Sidebar lives outside any data-spa-region: SidebarStateManager (scripts.js)
               patches active state from the destination doc on spa:commit so scroll
               position and any user-driven state survive across navigations. *@
            <nav id="nav-sidebar" aria-label="Sidebar" data-expanded="false" class="transition-[margin] ease-in-out duration-300 -ml-80 data-[expanded=true]:ml-0 lg:ml-0 w-80 lg:min-w-80 2xl:w-1/4 flex-none border-r border-base-200 dark:border-base-800 fixed lg:static lg:z-auto z-40 h-full lg:h-auto bg-base-50 dark:bg-base-950">
                <div class="sticky xl:ml-auto xl:w-80 2xl:w-92 py-6 px-6 font-display tracking-tight top-0 h-screen overflow-y-auto scrollbar-thin scrollbar-track-transparent scrollbar-thumb-base-300 dark:scrollbar-thumb-base-700 hover:scrollbar-thumb-base-400 dark:hover:scrollbar-thumb-base-600">
                    <div class="flex min-w-0 mb-6 items-center gap-x-2">
                        @if (DocSiteOptions.HeaderIcon != "")
                        {
                            @if (DocSiteOptions.HeaderIcon != null)
                            {
                                @((MarkupString)DocSiteOptions.HeaderIcon)
                            }
                            else
                            {
                                @_defaultHeaderIcon
                            }
                        }
                        <span class="font-display font-semibold tracking-tight text-base dark:text-base-50 text-base-900">
                            @if (DocSiteOptions.HeaderContent != null)
                            {
                                @((MarkupString)DocSiteOptions.HeaderContent)
                            }
                            else
                            {
                                <a href="/" class="hover:text-primary-700 dark:hover:text-primary-400 transition-colors">@DocSiteOptions.SiteTitle</a>
                            }
                        </span>
                    </div>
                    @if (DocSiteOptions.Areas.Count > 0)
                    {
                        <AreaNavigation Areas="DocSiteOptions.Areas" ActiveArea="_activeArea" AreaHrefs="_areaHrefs" />
                        @foreach (var area in DocSiteOptions.Areas)
                        {
                            var isActive = _activeArea != null
                                && string.Equals(area.Slug, _activeArea.Slug, StringComparison.OrdinalIgnoreCase);
                            <div data-area-toc="@area.Slug" class="@(isActive ? null : "hidden")">
                                <TableOfContentsNavigation TableOfContents="_areaTocs.GetValueOrDefault(area.Slug)"
                                    ListGapClass="gap-1"
                                    ChildListClass="@TocChildListClass"
                                    SectionHeaderStructureClass="@TocSectionHeaderStructureClass"
                                    SectionHeaderColorClass="@TocSectionHeaderColorClass"
                                    LinkStructureClass="@TocLinkStructureClass"
                                    LinkColorClass="@TocLinkColorClass"
                                    RootLinkStructureClass="@TocLinkStructureClass"
                                    RootLinkColorClass="@TocLinkColorClass" />
                            </div>
                        }
                    }
                    else
                    {
                        <TableOfContentsNavigation TableOfContents="_toc"
                            ListGapClass="gap-0"
                            ChildListClass="@TocChildListClass"
                            SectionHeaderStructureClass="@TocSectionHeaderStructureClass"
                            SectionHeaderColorClass="@TocSectionHeaderColorClass"
                            LinkStructureClass="@TocLinkStructureClass"
                            LinkColorClass="@TocLinkColorClass"
                            RootLinkStructureClass="@TocLinkStructureClass"
                            RootLinkColorClass="@TocLinkColorClass" />
                    }
                </div>
            </nav>
            <div class="flex-1 min-w-0 lg:ml-0">
                @* Header is intentionally NOT a data-spa-region: SearchManager
                   keeps a reference to #search-input, and swapping the header
                   on every navigation replaces that node and breaks the
                   click-to-open-modal handler. The LanguageSwitcher's per-page
                   alternates and current-locale highlight are kept in sync via
                   LanguageSwitcherManager.patch on spa:commit, mirroring the
                   sidebar pattern. *@
                <DocSiteHeader ShowMobileMenuButton="true" AlternateLanguages="_langSwitcherItems" />
                <main class="mx-auto max-w-7xl">
                    <div class="flex lg:gap-x-8 xl:gap-x-12">
                        <article id="main-content" data-spa-region="content" data-spa-loading="skeleton" class="flex-1 mt-4 lg:mt-8 ml-4 lg:ml-8 mr-4 xl:mr-0 min-w-0">
                            @Body
                        </article>
                        @* `outline` is a swap region so the MainLayout region
                           set differs from FullWidthLayout's (`content` only),
                           preserving the explicit layout-boundary fallback in
                           spa-engine.js. The list inside is JS-populated by
                           OutlineManager on every spa:commit, so swapping the
                           empty server-rendered shell is harmless. *@
                        <div data-spa-region="outline" data-spa-no-transition class="hidden xl:block sticky top-24 h-min  lg:max-h-[calc(100vh-7rem)] overflow-y-auto w-80  font-display tracking-tight text-sm">
                            <OutlineNavigation ContentSelector="#main-content" />
                        </div>
                    </div>

                    <DocSiteFooter />
                </main>
            </div>
        </div>
    </div>
</div>

@code{
    // Shared TOC styling — area-aware and single-tree branches pass the same strings.
    // The pill-style nav links replaced the previous border-l indicator; the active
    // state is now a tinted background, matching the area-pill / outline-rail family.
    private const string TocChildListClass = "mt-1 flex flex-col gap-0.5";

    private const string TocSectionHeaderStructureClass =
        "font-display text-[12.5px] font-semibold mt-6 first:mt-0 mb-2 px-2.5";

    private const string TocSectionHeaderColorClass = "text-base-500 dark:text-base-500";

    private const string TocLinkStructureClass =
        "flex items-center gap-1.5 px-2.5 py-1.5 rounded-md text-sm leading-snug";

    private const string TocLinkColorClass =
        "transition-colors duration-150 " +
        "text-base-500 dark:text-base-400 " +
        "hover:text-base-900 hover:bg-base-100 dark:hover:text-base-50 dark:hover:bg-base-900 " +
        "data-[current=true]:text-primary-700 data-[current=true]:bg-primary-500/8 " +
        "dark:data-[current=true]:text-primary-300 dark:data-[current=true]:bg-primary-300/8 " +
        "data-[current=true]:font-medium";

    private ImmutableList<NavigationTreeItem>? _toc;
    private Dictionary<string, ImmutableList<NavigationTreeItem>> _areaTocs = new();
    private Dictionary<string, string> _areaHrefs = new();
    private IReadOnlyList<LanguageSwitcher.AlternateLanguageItem> _langSwitcherItems = [];
    private ContentArea? _activeArea;

    private readonly RenderFragment _defaultHeaderIcon =
        @<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
              class="transition-all h-5 w-5 text-primary-600 dark:text-primary-400"
              stroke="currentColor">
            <defs/>
            <path fill="currentColor"
                  d="M10.444,1.25 L11.556,1.25 C13.394,1.25 14.85,1.25 15.989,1.403 C17.161,1.561 18.11,1.893 18.859,2.641 C19.607,3.39 19.939,4.339 20.097,5.511 C20.25,6.649 20.25,8.104 20.25,9.94 L20.25,11 C20.25,11.414 19.914,11.75 19.5,11.75 C19.086,11.75 18.75,11.414 18.75,11 L18.75,10 C18.75,8.093 18.748,6.739 18.61,5.711 C18.475,4.705 18.221,4.125 17.798,3.702 C17.375,3.279 16.795,3.025 15.789,2.89 C14.761,2.752 13.407,2.75 11.5,2.75 L10.5,2.75 C8.593,2.75 7.239,2.752 6.211,2.89 C5.205,3.025 4.625,3.279 4.202,3.702 C3.779,4.125 3.525,4.705 3.39,5.711 C3.252,6.738 3.25,8.093 3.25,10 L3.25,14 C3.25,15.907 3.252,17.261 3.39,18.289 C3.525,19.295 3.779,19.875 4.202,20.298 C4.625,20.721 5.205,20.975 6.211,21.11 C7.238,21.248 8.593,21.25 10.5,21.25 C10.914,21.25 11.25,21.586 11.25,22 C11.25,22.414 10.914,22.75 10.5,22.75 L10.444,22.75 C8.606,22.75 7.15,22.75 6.011,22.597 C4.838,22.439 3.89,22.107 3.141,21.359 C2.393,20.61 2.061,19.661 1.903,18.489 C1.75,17.35 1.75,15.894 1.75,14.057 L1.75,14.056 L1.75,9.944 C1.75,8.106 1.75,6.65 1.903,5.511 C2.061,4.339 2.393,3.39 3.141,2.641 C3.89,1.893 4.839,1.561 6.011,1.403 C7.15,1.25 8.606,1.25 10.444,1.25 Z M20.19,13.432 C20.452,13.562 20.675,13.786 20.888,14 L20.944,14.056 L21,14.113 C21.214,14.325 21.438,14.548 21.568,14.81 C21.811,15.3 21.811,15.876 21.568,16.366 C21.438,16.628 21.214,16.851 21,17.063 L20.944,17.12 L16.12,21.944 L16.064,22 C15.834,22.232 15.586,22.481 15.259,22.617 C14.932,22.752 14.58,22.751 14.254,22.75 L14.254,22.75 L14.174,22.75 L13,22.75 C12.586,22.75 12.25,22.414 12.25,22 L12.25,20.827 L12.25,20.747 C12.249,20.42 12.248,20.069 12.384,19.742 C12.519,19.415 12.769,19.167 13,18.937 L13.057,18.88 L17.88,14.056 L17.937,14 C18.15,13.786 18.372,13.562 18.634,13.432 C19.124,13.189 19.7,13.189 20.19,13.432 Z M6.25,7 C6.25,6.586 6.586,6.25 7,6.25 L15,6.25 C15.414,6.25 15.75,6.586 15.75,7 C15.75,7.414 15.414,7.75 15,7.75 L7,7.75 C6.586,7.75 6.25,7.414 6.25,7 Z M6.25,12 C6.25,11.586 6.586,11.25 7,11.25 L15,11.25 C15.414,11.25 15.75,11.586 15.75,12 C15.75,12.414 15.414,12.75 15,12.75 L7,12.75 C6.586,12.75 6.25,12.414 6.25,12 Z M19.236,14.83 C19.169,14.89 19.083,14.974 18.941,15.117 L14.117,19.941 C13.965,20.093 13.88,20.179 13.821,20.248 C13.795,20.278 13.781,20.297 13.775,20.306 C13.772,20.311 13.771,20.313 13.77,20.315 L13.769,20.316 L13.769,20.317 C13.769,20.318 13.768,20.321 13.767,20.326 C13.764,20.338 13.761,20.36 13.758,20.4 C13.751,20.491 13.75,20.611 13.75,20.827 L13.75,21.25 L14.174,21.25 C14.389,21.25 14.51,21.25 14.6,21.243 C14.641,21.24 14.663,21.236 14.674,21.234 C14.676,21.233 14.677,21.233 14.679,21.233 C14.681,21.232 14.683,21.232 14.683,21.231 L14.685,21.231 L14.686,21.23 C14.687,21.23 14.69,21.228 14.694,21.225 C14.704,21.219 14.722,21.206 14.753,21.18 C14.822,21.12 14.907,21.035 15.06,20.883 L19.883,16.059 C20.026,15.917 20.111,15.832 20.17,15.764 C20.208,15.722 20.222,15.702 20.225,15.697 C20.259,15.628 20.259,15.548 20.225,15.479 C20.222,15.474 20.208,15.454 20.17,15.412 C20.111,15.344 20.026,15.259 19.883,15.117 C19.741,14.974 19.656,14.89 19.589,14.83 C19.546,14.792 19.526,14.778 19.521,14.775 C19.452,14.742 19.372,14.742 19.303,14.775 C19.298,14.778 19.278,14.792 19.236,14.83 Z"/>
        </svg>;

    private static string? FirstLeafUrl(ImmutableList<NavigationTreeItem> items)
    {
        foreach (var item in items)
        {
            if (item.Children.Count == 0)
                return item.Route.CanonicalPath.Value;
            if (FirstLeafUrl(item.Children) is { } childUrl)
                return childUrl;
        }
        return null;
    }

    protected override async Task OnInitializedAsync()
    {
        var currentPath = NavigationManager.ToAbsoluteUri(NavigationManager.Uri).AbsolutePath;

        // Middleware such as the API reference rewriter swaps Request.Path for
        // internal routing; honor the preserved public path so area resolution
        // and TOC selection match the URL the user actually sees.
        if (HttpContextAccessor.HttpContext?.Items[DocSiteHttpContextKeys.OriginalPath] is string originalPath)
        {
            currentPath = originalPath;
        }

        // The 404-generation sentinel produces 404.html, not a real content route.
        // Normalize it so the TOC "current page" marker and language switcher treat
        // 404.html as if we were on the landing page.
        if (string.Equals(currentPath, OutputGenerationService.NotFoundGeneratorPath, StringComparison.Ordinal))
        {
            currentPath = "/";
        }

        var locale = Localization.IsMultiLocale ? Localization.GetLocaleFromUrl(currentPath) : null;

        var currentRoute = new ContentRoute
        {
            CanonicalPath = new UrlPath(currentPath),
            OutputFile = new FilePath($"{currentPath.TrimStart('/')}/index.html"),
        };

        if (DocSiteOptions.Areas.Count > 0)
        {
            _activeArea = ContentResolver.ResolveCurrentArea(currentPath) ?? DocSiteOptions.Areas[0];
            foreach (var area in DocSiteOptions.Areas)
            {
                var areaTocItems = await ContentResolver.GetTocItemsForAreaAsync(locale, area);
                var tree = NavBuilder.BuildTree(areaTocItems.ToList(), currentRoute, locale);
                _areaTocs[area.Slug] = tree;
                if (FirstLeafUrl(tree) is { } firstUrl)
                    _areaHrefs[area.Slug] = firstUrl;
            }
        }
        else
        {
            var tocItems = await ContentResolver.GetTocItemsForAreaAsync(locale, null);
            _toc = NavBuilder.BuildTree(tocItems.ToList(), currentRoute, locale);
        }

        // Build language switcher items
        if (Localization.IsMultiLocale)
        {
            var alternates = await ContentResolver.GetAlternateLanguagesAsync(currentPath);
            _langSwitcherItems = alternates
                .Select(a => new LanguageSwitcher.AlternateLanguageItem(
                    a.Locale, a.DisplayName, a.Route.CanonicalPath.Value, a.IsCurrentLocale))
                .ToList();
        }

        await base.OnInitializedAsync();
    }
}
