@page "/{*fileName:nonfile}"
@using Pennington.DocSite.Services
@using Pennington.DocSite.StructuredData
@using Pennington.Infrastructure
@using Pennington.Localization
@using Pennington.StructuredData
@inject DocSiteContentResolver ContentResolver
@inject NavigationBuilder NavBuilder
@inject DocSiteOptions DocSiteOptions
@inject NavigationManager NavigationManager
@inject LocalizationOptions Localization
@inject IHttpContextAccessor HttpContextAccessor
@inject Microsoft.Extensions.Localization.IStringLocalizer<Pages> Localizer

@if (_resolved != null)
{
    <PageTitle>@_resolved.Title — @DocSiteOptions.SiteTitle</PageTitle>
    <HeadContent>
        <meta name="description" content="@_resolved.Description" />
        @foreach (var alt in _alternateLanguages)
        {
            var hreflang = Localization.Locales.TryGetValue(alt.Locale, out var info)
                ? info.HtmlLang ?? alt.Locale
                : alt.Locale;
            <link rel="alternate" hreflang="@hreflang" href="@alt.Route.CanonicalPath.Value" />
        }
    </HeadContent>
    @if (!string.IsNullOrEmpty(DocSiteOptions.CanonicalBaseUrl))
    {
        <StructuredData Entities="BuildArticleEntities()" />
    }
    <DocSiteArticle
        Title="@_resolved.Title"
        Description="@_resolved.Description"
        HtmlContent="@_resolved.Html"
        AreaTitle="@_activeArea?.Title"
        AreaIconHtml="@_activeArea?.Icon"
        PreviousPageName="@_navInfo?.PreviousPage?.Title"
        PreviousPageHref="@_navInfo?.PreviousPage?.Route.CanonicalPath.Value"
        NextPageName="@_navInfo?.NextPage?.Title"
        NextPageHref="@_navInfo?.NextPage?.Route.CanonicalPath.Value"
        FallbackRequestedLocale="@_resolved.FallbackRequestedDisplayName"
        FallbackDefaultLocale="@_resolved.FallbackDefaultDisplayName" />

}
else if (_homeComponentType != null)
{
    @if (!string.IsNullOrEmpty(DocSiteOptions.CanonicalBaseUrl))
    {
        <StructuredData Entities="BuildHomeEntities()" />
    }
    <DynamicComponent Type="_homeComponentType" />
}
else if (_notFound)
{
    <PageTitle>@Localizer["pennington.notfound.title"]</PageTitle>
    <p>@Localizer["pennington.notfound.body"]</p>
}

@code {
    [Parameter] public string? FileName { get; set; }

    private ResolvedContent? _resolved;
    private NavigationInfo? _navInfo;
    private ContentArea? _activeArea;
    private bool _notFound;
    private Type? _homeComponentType;
    private ImmutableList<AlternateLanguagePage> _alternateLanguages = ImmutableList<AlternateLanguagePage>.Empty;

    private IEnumerable<JsonLdEntity> BuildArticleEntities()
    {
        if (_resolved == null || string.IsNullOrEmpty(DocSiteOptions.CanonicalBaseUrl))
        {
            yield break;
        }

        var baseUrl = DocSiteOptions.CanonicalBaseUrl.TrimEnd('/');
        var canonicalUrl = $"{baseUrl}{_resolved.Route.CanonicalPath.EnsureTrailingSlash().Value}";

        // A record's own IHasStructuredData entities are emitted centrally by
        // StructuredDataHtmlRewriter. The template only adds what the rewriter can't know: a
        // default Article for front matter that describes none (so DocSite stays useful for SEO),
        // and the nav-derived breadcrumb trail below.
        if (_resolved.Metadata is not IHasStructuredData)
        {
            yield return new JsonLdArticle
            {
                Headline = _resolved.Title,
                Description = _resolved.Description,
                Url = canonicalUrl,
                DatePublished = _resolved.Metadata.Date,
            };
        }

        // Breadcrumbs are page-level navigation, not front-matter-level —
        // they depend on the nav tree, not on the page's own fields.
        if (_navInfo?.Breadcrumbs is { Count: > 0 } crumbs)
        {
            var items = crumbs.Select((b, i) => new JsonLdBreadcrumbItem
            {
                Position = i + 1,
                Name = b.Title,
                Url = b.Route?.CanonicalPath.Value is { Length: > 0 }
                    ? $"{baseUrl}{b.Route.CanonicalPath.EnsureTrailingSlash().Value}"
                    : null,
            }).ToList();
            yield return new JsonLdBreadcrumbList { Items = items };
        }
    }

    private IEnumerable<JsonLdEntity> BuildHomeEntities()
    {
        if (string.IsNullOrEmpty(DocSiteOptions.CanonicalBaseUrl))
        {
            yield break;
        }

        yield return new JsonLdWebSite
        {
            Name = DocSiteOptions.SiteTitle,
            Url = DocSiteOptions.CanonicalBaseUrl.TrimEnd('/') + "/",
            Description = DocSiteOptions.SiteDescription,
        };
    }

    protected override async Task OnInitializedAsync()
    {
        // Use the full request path (including any locale prefix) rather than the
        // FileName route parameter — Blazor routing sees a locale-stripped path
        // because LocaleDetectionMiddleware moves the locale into PathBase, so
        // FileName alone would cause ContentResolver to miss locale-specific routes.
        var url = NavigationManager.ToAbsoluteUri(NavigationManager.Uri).AbsolutePath;
        if (string.IsNullOrWhiteSpace(url) || url == "/") url = "index";

        _resolved = await ContentResolver.GetContentByUrlAsync(url);

        if (_resolved is { IsFallback: true, Locale: { Length: > 0 } actualLocale }
            && HttpContextAccessor.HttpContext is { } ctx)
        {
            // Surface the actual content locale to FallbackLangHtmlRewriter so
            // <html lang> ends up matching the body's language rather than the
            // URL's locale prefix.
            ctx.Items[FallbackLangHtmlRewriter.FallbackContentLocaleKey] = actualLocale;
        }

        if (_resolved != null)
        {
            _activeArea = ContentResolver.ResolveCurrentArea(url);
            _navInfo = await ContentResolver.GetNavigationInfoForAreaAsync(url, _activeArea);
            if (Localization.IsMultiLocale)
            {
                _alternateLanguages = await ContentResolver.GetAlternateLanguagesAsync(url);
            }
        }
        else if (url == "index")
        {
            // Try to find an Index Razor component registered via @page
            _homeComponentType = AppDomain.CurrentDomain.GetAssemblies()
                .SelectMany(a => { try { return a.GetTypes(); } catch { return []; } })
                .FirstOrDefault(t => t.Name == "Index"
                    && typeof(IComponent).IsAssignableFrom(t)
                    && !t.IsAbstract
                    && t != typeof(Pages)); // Don't match ourselves
        }
        else
        {
            _notFound = true;
            if (HttpContextAccessor.HttpContext is { } notFoundCtx)
            {
                // Signal to NotFoundStatusProcessor to flip status to 404 AFTER
                // all body rewriting has run — setting it here directly would
                // gate every IResponseProcessor (ShouldProcess returns false on
                // non-2xx) and produce an empty response body.
                notFoundCtx.Items["Pennington.NotFound"] = true;
            }
        }
    }
}
