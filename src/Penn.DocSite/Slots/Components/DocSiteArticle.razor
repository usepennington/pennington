<header class="transition-all mb-4 lg:mb-8">
    <h1 class="font-display text-2xl lg:text-4xl font-bold tracking-tight text-base-900 dark:text-base-50">@Title</h1>
</header>

<main class="prose dark:prose-invert dark:text-base-300 max-w-full prose-sm md:prose-base min-w-0 prose-headings:scroll-m-18 prose-headings:font-display prose-headings:text-base-900 dark:prose-headings:text-base-50">
    @((MarkupString)HtmlContent)
</main>

@if (PreviousPageName is not null || NextPageName is not null)
{
    <div class="flex my-12 border-t border-base-200 dark:border-base-700 pt-4 lg:pt-8">
        @if (PreviousPageName is not null)
        {
            @NavButton(PreviousPageName, PreviousPageHref!, false)
        }
        @if (NextPageName is not null)
        {
            @NavButton(NextPageName, NextPageHref!, true)
        }
    </div>
}

@code {
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public string HtmlContent { get; set; } = "";
    [Parameter] public string? PreviousPageName { get; set; }
    [Parameter] public string? PreviousPageHref { get; set; }
    [Parameter] public string? NextPageName { get; set; }
    [Parameter] public string? NextPageHref { get; set; }

    private const string BtnClass =
        "inline-flex gap-0.5 justify-center overflow-hidden text-sm font-medium font-display transition " +
        "rounded-xl bg-base-200 pt-1.5 pb-1 px-3 lg:pt-2 lg:pb.15 lg:px-4 " +
        "hover:bg-base-300/75 dark:bg-base-800/40 text-base-800 dark:text-base-400 " +
        "ring-1 dark:ring-inset ring-base-300/75 dark:ring-base-800 " +
        "dark:hover:bg-base-800 dark:hover:text-base-300";

    private const string LblClass =
        "text-sm lg:text-base font-semibold text-base-700 transition " +
        "hover:text-base-600 dark:text-base-400 dark:hover:text-base-300";

    private static readonly RenderFragment ArrowSvg =
        @<svg viewBox="0 0 20 20" fill="none" aria-hidden="true" class="mt-0.5 h-5 w-5">
            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"
                  d="m11.5 6.5 3 3.5m0 0-3 3.5m3-3.5h-9"></path>
        </svg>;

    private RenderFragment NavButton(string name, string href, bool isNext) =>
        @<div class="flex flex-col items-@(isNext ? "end" : "start") @(isNext ? "ml-auto" : "") gap-3">
            <a class="@BtnClass"
               aria-label="@(isNext ? "Next" : "Previous"): @name" href="@href">
                @if (!isNext) { <span class="-ml-1 rotate-180">@ArrowSvg</span> <text>Previous</text> }
                @if (isNext) { <text>Next</text> <span class="-mr-1">@ArrowSvg</span> }
            </a>
            <a tabindex="-1" aria-hidden="true" class="@LblClass" href="@href">@name</a>
        </div>;
}
