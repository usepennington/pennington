<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net11.0;net10.0</TargetFrameworks>
    <LangVersion>preview</LangVersion>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>Pennington</RootNamespace>
    <Description>Content engine for .NET with Markdown processing, front matter, and static site generation</Description>
    <PackageTags>dotnet markdown static-site-generator content-engine front-matter yaml</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Pennington.Tests" />
  </ItemGroup>
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Testably.Abstractions" Version="10.2.0" />
    <PackageReference Include="YamlDotNet" Version="16.3.0" />
    <PackageReference Include="Markdig" Version="*" />
    <PackageReference Include="AngleSharp" Version="*" />
    <PackageReference Include="Mdazor" Version="0.0.0-alpha.0.13" />
    <PackageReference Include="TextMateSharp" Version="*" />
    <PackageReference Include="TextMateSharp.Grammars" Version="*" />
    <PackageReference Include="System.ServiceModel.Syndication" Version="*" />
  </ItemGroup>
</Project>
