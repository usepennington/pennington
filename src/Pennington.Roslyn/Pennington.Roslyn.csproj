<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net10.0;net11.0</TargetFrameworks>
    <LangVersion>preview</LangVersion>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <Description>Roslyn-based code analysis and highlighting for Pennington</Description>
    <PackageTags>dotnet roslyn syntax-highlighting code-analysis</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Pennington.Roslyn.Tests" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Pennington\Pennington.csproj" />
    <ProjectReference Include="..\Pennington.ApiMetadata\Pennington.ApiMetadata.csproj" />
  </ItemGroup>
  <ItemGroup>
    <Compile Include="..\Pennington\Infrastructure\UnionPolyfills.cs" Link="Infrastructure\UnionPolyfills.cs" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp.Workspaces" Version="5.3.0" />
    <PackageReference Include="Microsoft.CodeAnalysis.VisualBasic.Workspaces" Version="5.3.0" />
    <PackageReference Include="Microsoft.CodeAnalysis.Workspaces.MSBuild" Version="5.3.0" />
    <PackageReference Include="Microsoft.Build.Locator" Version="1.11.2" />
    <PackageReference Include="Microsoft.Build.Tasks.Core" Version="18.4.0" ExcludeAssets="runtime" />
    <PackageReference Include="Microsoft.Build.Framework" Version="18.4.0" ExcludeAssets="runtime" PrivateAssets="all" />
    <PackageReference Include="DiffPlex" Version="1.9.0" />
    
    <!-- explicitly installed due to https://github.com/advisories/GHSA-37gx-xxp4-5rgx and others -->
    <PackageReference Include="System.Security.Cryptography.Xml" Version="10.0.6" />
  </ItemGroup>
</Project>
