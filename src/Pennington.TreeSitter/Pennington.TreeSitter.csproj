<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net10.0;net11.0</TargetFrameworks>
    <LangVersion>preview</LangVersion>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <Description>Tree-sitter based multi-language code-fragment extraction for Pennington</Description>
    <PackageTags>dotnet tree-sitter syntax code-fragments documentation</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Pennington.TreeSitter.Tests" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Pennington\Pennington.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="TreeSitter.DotNet" />
    <PackageReference Include="DiffPlex" />
  </ItemGroup>
</Project>
