@inject IServiceProvider Services
@if (!string.IsNullOrWhiteSpace(Title))
{
    <div class="@_titleStructure @_titleColor">@Title</div>
}
<div data-role="page-outline" data-content-selector="@ContentSelector" class="relative @_containerStructure @_containerColor">
    <div data-role="page-outline-highlighter" class="absolute transition-all duration-500 opacity-0 left-[-1px] w-[2px] rounded-sm bg-primary-600 dark:bg-primary-300"></div>
    <div>
        <ul class="@_listStructure @_listColor"
            data-outline-link-structure-class="@_linkStructure"
            data-outline-link-color-class="@_linkColor">
            @* Outline links will be dynamically generated by JavaScript *@
        </ul>
    </div>
</div>

@code {
    /// <summary>CSS selector the client-side outline script queries to discover heading elements; must be non-empty for the outline to populate.</summary>
    [Parameter, EditorRequired] public string ContentSelector { get; set; } = "";

    /// <summary>Optional eyebrow rendered above the outline; pass an empty string to suppress.</summary>
    [Parameter] public string Title { get; set; } = "On this page";

    /// <summary>Layout and typography classes applied to the eyebrow above the outline list. When null, falls back to the <c>outline.title-structure</c> style-registry slot; an explicit value is used verbatim.</summary>
    [Parameter] public string? TitleStructureClass { get; set; }

    /// <summary>CSS classes applied to the eyebrow text. When null, falls back to the <c>outline.title-color</c> style-registry slot; an explicit value is used verbatim.</summary>
    [Parameter] public string? TitleColorClass { get; set; }

    /// <summary>Layout and border classes applied to the outer <c>data-role="page-outline"</c> container. When null, falls back to the <c>outline.container-structure</c> style-registry slot; an explicit value is used verbatim.</summary>
    [Parameter] public string? ContainerStructureClass { get; set; }

    /// <summary>CSS classes applied to the outer container for color treatment, composed after <see cref="ContainerStructureClass"/>. When null, falls back to the <c>outline.container-color</c> style-registry slot; an explicit value is used verbatim.</summary>
    [Parameter] public string? ContainerColorClass { get; set; }

    /// <summary>Layout classes applied to the outline <c>&lt;ul&gt;</c>. When null, falls back to the <c>outline.list-structure</c> style-registry slot; an explicit value is used verbatim.</summary>
    [Parameter] public string? ListStructureClass { get; set; }

    /// <summary>CSS classes applied to the <c>&lt;ul&gt;</c> that holds outline links, composed after <see cref="ListStructureClass"/>. When null, falls back to the <c>outline.list-color</c> style-registry slot; an explicit value is used verbatim.</summary>
    [Parameter] public string? ListColorClass { get; set; }

    /// <summary>CSS classes emitted on the container as <c>data-outline-link-color-class</c> and applied by the client-side script to each generated <c>&lt;li&gt;&lt;a&gt;</c> for color and <c>data-selected=true</c> state. When null, falls back to the <c>outline.link-color</c> style-registry slot; an explicit value is used verbatim.</summary>
    [Parameter] public string? OutlineLinkColorClass { get; set; }

    /// <summary>Layout classes emitted on the container as <c>data-outline-link-structure-class</c> and applied by the client-side script to each generated <c>&lt;li&gt;&lt;a&gt;</c>. When null, falls back to the <c>outline.link-structure</c> style-registry slot; an explicit value is used verbatim.</summary>
    [Parameter] public string? OutlineLinkStructureClass { get; set; }

    // Optional resolve: bare hosts that never call AddPenningtonStyles still render with the
    // built-in defaults. Blazor's [Inject] has no optional mode, hence GetService.
    private StyleRegistry? _styles;

    private string _titleStructure = "";
    private string _titleColor = "";
    private string _containerStructure = "";
    private string _containerColor = "";
    private string _listStructure = "";
    private string _listColor = "";
    private string _linkStructure = "";
    private string _linkColor = "";

    protected override void OnInitialized() => _styles = Services.GetService<StyleRegistry>();

    protected override void OnParametersSet()
    {
        _titleStructure = Resolve(TitleStructureClass, StyleKeys.OutlineTitleStructure);
        _titleColor = Resolve(TitleColorClass, StyleKeys.OutlineTitleColor);
        _containerStructure = Resolve(ContainerStructureClass, StyleKeys.OutlineContainerStructure);
        _containerColor = Resolve(ContainerColorClass, StyleKeys.OutlineContainerColor);
        _listStructure = Resolve(ListStructureClass, StyleKeys.OutlineListStructure);
        _listColor = Resolve(ListColorClass, StyleKeys.OutlineListColor);
        _linkStructure = Resolve(OutlineLinkStructureClass, StyleKeys.OutlineLinkStructure);
        _linkColor = Resolve(OutlineLinkColorClass, StyleKeys.OutlineLinkColor);
    }

    private string Resolve(string? parameter, string key)
        => parameter ?? _styles?[key] ?? UiStyleDefaults.Get(key);
}
