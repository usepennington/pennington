@inject IServiceProvider Services
@if (TableOfContents != null)
{
    <nav>
        <ul class="flex flex-col @_listGap">
            @foreach (var tableOfContentEntry in TableOfContents.OrderBy(i => i.Order))
            {
                @TocEntry(tableOfContentEntry)
            }
        </ul>
    </nav>
}

@code {
    /// <summary>Navigation tree to render; when null the component renders nothing, and entries are sorted by <see cref="NavigationTreeItem.Order"/> at each level.</summary>
    [Parameter] public ImmutableList<NavigationTreeItem>? TableOfContents { get; set; }

    /// <summary>Optional label forwarded from the caller's <c>NavigationInfo.SectionName</c>; not rendered by the default template.</summary>
    [Parameter] public string? SectionLabel { get; set; }

    /// <summary>CSS classes applied to the outer <c>&lt;ul&gt;</c> that holds the top-level navigation entries. When null, falls back to the <c>toc.list-gap</c> style-registry slot; an explicit value is used verbatim.</summary>
    [Parameter] public string? ListGapClass { get; set; }

    /// <summary>CSS classes applied to the nested <c>&lt;ul&gt;</c> that holds a section's child entries. When null, falls back to the <c>toc.child-list</c> style-registry slot; an explicit value is used verbatim.</summary>
    [Parameter] public string? ChildListClass { get; set; }

    /// <summary>Layout and typography classes applied to the section-header element. When null, falls back to the <c>toc.section-header-structure</c> style-registry slot; an explicit value is used verbatim.</summary>
    [Parameter] public string? SectionHeaderStructureClass { get; set; }

    /// <summary>CSS classes applied to section-header text — both the plain <c>&lt;div&gt;</c> for empty-route entries and the <c>&lt;a&gt;</c> when a top-level entry has children. When null, falls back to the <c>toc.section-header-color</c> style-registry slot; an explicit value is used verbatim.</summary>
    [Parameter] public string? SectionHeaderColorClass { get; set; }

    /// <summary>Layout and typography classes applied to each child-level <c>&lt;a&gt;</c> element under a section. When null, falls back to the <c>toc.link-structure</c> style-registry slot; an explicit value is used verbatim.</summary>
    [Parameter] public string? LinkStructureClass { get; set; }

    /// <summary>CSS classes applied to each child-level <c>&lt;a&gt;</c> for color and <c>data-current=true</c> state, composed after <see cref="LinkStructureClass"/>. When null, falls back to the <c>toc.link-color</c> style-registry slot; an explicit value is used verbatim.</summary>
    [Parameter] public string? LinkColorClass { get; set; }

    /// <summary>Layout classes applied to a leaf root-level <c>&lt;a&gt;</c> when a top-level entry has no children. When null, falls back to the <c>toc.root-link-structure</c> style-registry slot; an explicit value is used verbatim.</summary>
    [Parameter] public string? RootLinkStructureClass { get; set; }

    /// <summary>CSS classes applied to a leaf root-level <c>&lt;a&gt;</c> (a top-level entry with no children), composed after <see cref="RootLinkStructureClass"/>. When null, falls back to the <c>toc.root-link-color</c> style-registry slot; an explicit value is used verbatim.</summary>
    [Parameter] public string? RootLinkColorClass { get; set; }

    // Optional resolve: bare hosts that never call AddPenningtonStyles still render with the
    // built-in defaults. Blazor's [Inject] has no optional mode, hence GetService.
    private StyleRegistry? _styles;

    private string _listGap = "";
    private string _childList = "";
    private string _sectionHeaderStructure = "";
    private string _sectionHeaderColor = "";
    private string _linkStructure = "";
    private string _linkColor = "";
    private string _rootLinkStructure = "";
    private string _rootLinkColor = "";

    protected override void OnInitialized() => _styles = Services.GetService<StyleRegistry>();

    protected override void OnParametersSet()
    {
        _listGap = Resolve(ListGapClass, StyleKeys.TocListGap);
        _childList = Resolve(ChildListClass, StyleKeys.TocChildList);
        _sectionHeaderStructure = Resolve(SectionHeaderStructureClass, StyleKeys.TocSectionHeaderStructure);
        _sectionHeaderColor = Resolve(SectionHeaderColorClass, StyleKeys.TocSectionHeaderColor);
        _linkStructure = Resolve(LinkStructureClass, StyleKeys.TocLinkStructure);
        _linkColor = Resolve(LinkColorClass, StyleKeys.TocLinkColor);
        _rootLinkStructure = Resolve(RootLinkStructureClass, StyleKeys.TocRootLinkStructure);
        _rootLinkColor = Resolve(RootLinkColorClass, StyleKeys.TocRootLinkColor);
    }

    private string Resolve(string? parameter, string key)
        => parameter ?? _styles?[key] ?? UiStyleDefaults.Get(key);

    private RenderFragment TocEntry(NavigationTreeItem tocEntry) =>
        @<li class="block mt-4 first:mt-0">
            @if (tocEntry.Route.CanonicalPath.Value == "")
            {
                <div class="@_sectionHeaderStructure @_sectionHeaderColor">@tocEntry.Title</div>
            }
            else
            {
                <a data-current="@tocEntry.IsSelected.ToString().ToLowerInvariant()" href="@tocEntry.Route.CanonicalPath.Value" class="@(tocEntry.Children.Count == 0 ? _rootLinkStructure + " " + _rootLinkColor : _sectionHeaderStructure + " " + _sectionHeaderColor)">@tocEntry.Title</a>
            }
            @if (tocEntry.Children.Count > 0)
            {
                <ul class="@_childList">
                    @foreach (var childEntry in tocEntry.Children.OrderBy(i => i.Order).Where(i => i.Route.CanonicalPath.Value != ""))
                    {
                        <li class="block">
                            <a data-current="@childEntry.IsSelected.ToString().ToLowerInvariant()" href="@childEntry.Route.CanonicalPath.Value" class="@_linkStructure @_linkColor">@childEntry.Title</a>
                        </li>
                    }
                </ul>
            }
        </li>;
}
