<div class="not-prose">
    <div class="group h-full relative rounded-xl border pn-card @CardColorClasses.Tint(Color)">
        <div class="relative flex flex-row gap-x-4 overflow-hidden rounded-xl p-6">
            @if (Icon != null)
            {
                <div class="pt-1 pn-card-icon">
                    @Icon
                </div>
            }
            <div>
                <h2 class="font-display font-bold pb-2" >@Title</h2>
                <div class="text-sm">
                    @ChildContent
                </div>
            </div>
        </div>
    </div>
</div>
@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public RenderFragment? Icon { get; set; }
    [Parameter] public string? Title { get; set; }
    [Parameter] public string Color { get; set; } = "primary";

}
