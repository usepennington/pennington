@* Container for ordered step-by-step instructions. Renders a vertical thread
   line on the left of the column; each child <Step> punches a numbered medallion
   onto the thread. Marked not-prose so the markdown prose layer doesn't restyle
   our chrome. *@

<div class="steps-thread not-prose">
    @ChildContent
</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
}
