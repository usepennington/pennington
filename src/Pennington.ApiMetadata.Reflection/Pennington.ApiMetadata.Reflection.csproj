<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net10.0;net11.0</TargetFrameworks>
    <LangVersion>preview</LangVersion>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <Description>Reflection-backed IApiMetadataProvider for Pennington — reads a compiled assembly plus its companion xmldoc XML file and surfaces them through the neutral API-metadata abstractions.</Description>
    <PackageTags>dotnet api-docs xmldoc reflection</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\Pennington\Pennington.csproj" />
    <ProjectReference Include="..\Pennington.ApiMetadata\Pennington.ApiMetadata.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="System.Reflection.MetadataLoadContext" />
  </ItemGroup>
</Project>
